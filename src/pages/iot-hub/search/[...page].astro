---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import {
	IOT_HUB_CATEGORIES,
	IOT_HUB_STRINGS,
	SEARCH_PAGE_SIZE,
	isNumericSlug,
	type ListingView,
} from '@models/iot-hub';
import BaseLayout from '@layouts/BaseLayout.astro';
import CategorySection from '@components/IotHub/CategorySection.astro';
import CategorySectionTemplate from '@components/IotHub/CategorySectionTemplate.astro';
import IotHubBreadcrumbs from '@components/IotHub/IotHubBreadcrumbs.astro';
import IotHubNoResults from '@components/IotHub/IotHubNoResults.astro';
import IotHubRuntimeConfig from '@components/IotHub/IotHubRuntimeConfig.astro';
import ListingCardTemplate from '@components/IotHub/ListingCardTemplate.astro';
import SearchFilterBar from '@components/IotHub/SearchFilterBar.astro';

const T = IOT_HUB_STRINGS.searchPage;

interface SearchGroup {
	slug: string;
	label: string;
	items: ListingView[];
}

export const getStaticPaths = (async () => {
	const categories = await getCollection('iotHubCategories');
	const byId = new Map(categories.map((c) => [c.id, c.data]));

	type SearchItem = { item: ListingView; categorySlug: string; categoryLabel: string };
	const allItems: SearchItem[] = [];
	for (const cat of IOT_HUB_CATEGORIES) {
		const items = byId.get(cat.slug)?.items ?? [];
		for (const item of items) {
			if (isNumericSlug(item.slug)) continue;
			allItems.push({ item, categorySlug: cat.slug, categoryLabel: cat.label });
		}
	}
	// Match the backend's order for `?sortProperty=installCount&sortOrder=DESC`
	// — installCount DESC, then createdTime DESC as tie-break — so the static
	// build and runtime refetches surface items in the same order.
	allItems.sort((a, b) => {
		const ic = (b.item.installCount ?? 0) - (a.item.installCount ?? 0);
		if (ic !== 0) return ic;
		return (b.item.createdTime ?? 0) - (a.item.createdTime ?? 0);
	});

	const total = allItems.length;
	const totalPages = Math.max(1, Math.ceil(total / SEARCH_PAGE_SIZE));

	return Array.from({ length: totalPages }, (_, i) => {
		const currentPage = i + 1;
		const slice = allItems.slice(i * SEARCH_PAGE_SIZE, currentPage * SEARCH_PAGE_SIZE);
		const groups: SearchGroup[] = IOT_HUB_CATEGORIES.map((cat) => ({
			slug: cat.slug,
			label: cat.label,
			items: slice.filter((s) => s.categorySlug === cat.slug).map((s) => s.item),
		})).filter((g) => g.items.length > 0);
		return {
			params: { page: currentPage === 1 ? undefined : String(currentPage) },
			props: { groups, currentPage, totalPages, total },
		};
	});
}) satisfies GetStaticPaths;

interface Props {
	groups: SearchGroup[];
	currentPage: number;
	totalPages: number;
	total: number;
}

const { groups, currentPage, totalPages, total } = Astro.props as Props;
const searchText = '';
const basePath = '/iot-hub/search/';
const title = 'Search | IoT Hub | ThingsBoard';
const description =
	'Search the ThingsBoard IoT Hub catalogue of devices, widgets, rule chains and more.';
---

<BaseLayout title={title} description={description}>
	<main class="iot-hub-search" data-iot-hub-search-root>
		<div class="iot-hub-search__center">
			<div class="iot-hub-search__container">
				<div class="iot-hub-search__breadcrumb">
					<IotHubBreadcrumbs
						items={[
							{ label: T.breadcrumbRoot, href: '/iot-hub/' },
							{ label: T.breadcrumbCurrent },
						]}
					/>
				</div>
				<div class="iot-hub-search__items">
					<SearchFilterBar
						searchText={searchText}
						totalResults={total}
						currentPage={currentPage}
						totalPages={totalPages}
						basePath={basePath}
					/>
					<div class="iot-hub-search__results-container">
						<div class="iot-hub-search__results" data-search-results>
							{groups.map((g) => (
								<CategorySection
									categorySlug={g.slug}
									categoryLabel={g.label}
									items={g.items}
									showCreator={true}
								/>
							))}
						</div>
						<IotHubNoResults />
						<div class="iot-hub-search__loading">
							<span
								class="iot-hub-search__spinner"
								role="progressbar"
								aria-label="Loading results"
							></span>
						</div>
					</div>
				</div>
			</div>
		</div>
		<ListingCardTemplate variant="big" />
		<ListingCardTemplate variant="compact" />
		<CategorySectionTemplate />
		<IotHubRuntimeConfig />
	</main>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;
	@use '~/styles/_iot-hub.scss' as *;

	.iot-hub-search {
		@include iot-hub-hairline-token;
	}

	.iot-hub-search__center {
		@include iot-hub-center;
	}

	.iot-hub-search__container {
		@include iot-hub-container;
	}

	.iot-hub-search__breadcrumb {
		padding: calc(#{$header-height} + 40px) 16px 0;

		@include media-down(sm) {
			padding: calc(#{$header-height} + 40px) 12px 0;
		}
	}

	.iot-hub-search__items {
		padding-bottom: 16px;
		position: relative;
	}

	.iot-hub-search__results-container {
		position: relative;
	}

	// Absolute overlay so dimensions stay stable across fetches.
	.iot-hub-search__loading {
		display: none;
		position: absolute;
		inset: 0;
		z-index: 5;
		justify-content: center;
		padding-top: 64px;
		background: rgba(255, 255, 255, 0.72);

		:global([data-theme='dark']) & {
			background: rgba(23, 24, 28, 0.72);
		}
	}

	.iot-hub-search__items.is-loading .iot-hub-search__loading {
		display: flex;
	}

	.iot-hub-search__spinner {
		width: 64px;
		height: 64px;
		border: 6px solid var(--color-bg-light, rgba(0, 0, 0, 0.08));
		border-top-color: var(--color-primary);
		border-radius: 50%;
		animation: iot-hub-search-spin 0.8s linear infinite;

		:global([data-theme='dark']) & {
			border-color: rgba(255, 255, 255, 0.12);
			border-top-color: #b3c7ff;
		}
	}

	@keyframes iot-hub-search-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-search__spinner {
			animation-duration: 2.4s;
		}
	}
</style>

<script>
	// Dynamic search. Triggers (each clears + refetches):
	//   * SearchFilterBar input (300ms debounce) — resets page to 1
	//   * IotHubSort selection                   — resets page to 1
	//   * Pagination items-per-page              — resets page to 1
	//   * Pagination page change                 — keeps page index
	// After the first dynamic fetch, pagination switches to event-based mode
	// and totalElements / totalPages are driven by the PageData response.
	// On load, `?q=` triggers an immediate fetch so URL state wins over SSR.
	import {
		IOT_HUB_API_URL,
		IOT_HUB_CATEGORIES,
		SEARCH_PAGE_SIZE,
		DEFAULT_IOT_HUB_SORT_ID,
		getCardVariant,
		getIotHubSortOption,
		type IotHubItemType,
		type ListingView,
	} from '@models/iot-hub';
	import { bindListingCard } from '@components/IotHub/iot-hub-listing-card-bind';
	import { getKnownSlugs } from '@components/IotHub/iot-hub-known-slugs';
	import {
		updatePaginationDynamic,
		updateResultsCount,
	} from '@components/IotHub/iot-hub-pagination-update';

	const DEBOUNCE_MS = 300;

	type PageData<T> = {
		data: T[];
		totalPages: number;
		totalElements: number;
		hasNext: boolean;
	};

	const ITEM_TYPE_BY_TYPE = new Map(IOT_HUB_CATEGORIES.map((c) => [c.itemType, c]));

	function init() {
		const root = document.querySelector<HTMLElement>('[data-iot-hub-search-root]');
		if (!root) return;

		const input = root.querySelector<HTMLInputElement>('[data-search-input]');
		const resultsContainer = root.querySelector<HTMLElement>('[data-search-results]');
		const itemsWrap = root.querySelector<HTMLElement>('.iot-hub-search__items');
		const paginationNav = root.querySelector<HTMLElement>('[data-iot-hub-pagination]');
		const countEl = root.querySelector<HTMLElement>('.search-bar__count');
		const noResults = root.querySelector<HTMLElement>('[data-iot-hub-no-results]');
		if (!input || !resultsContainer || !itemsWrap || !countEl || !noResults) return;

		const bigTmpl = document.querySelector<HTMLTemplateElement>(
			'[data-listing-card-tmpl][data-variant="big"]'
		);
		const compactTmpl = document.querySelector<HTMLTemplateElement>(
			'[data-listing-card-tmpl][data-variant="compact"]'
		);
		const sectionTmpl = document.querySelector<HTMLTemplateElement>(
			'[data-category-section-tmpl]'
		);
		if (!bigTmpl || !compactTmpl || !sectionTmpl) return;

		let searchText = '';
		let sortId: string = DEFAULT_IOT_HUB_SORT_ID;
		let pageSize = SEARCH_PAGE_SIZE;
		let currentPage = 1;
		let abort: AbortController | null = null;
		let debounceTimer: number | undefined;

		function setLoading(loading: boolean): void {
			itemsWrap!.classList.toggle('is-loading', loading);
		}

		function showNoResults(show: boolean): void {
			noResults!.hidden = !show;
			if (show) resultsContainer!.replaceChildren();
		}

		function buildCardNode(item: ListingView, categorySlug: string): HTMLElement {
			const variant = getCardVariant(item.itemType);
			const tmpl = variant === 'big' ? bigTmpl! : compactTmpl!;
			const card = tmpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
			bindListingCard(card, item, categorySlug, true);
			return card;
		}

		function buildSectionNode(
			slug: string,
			label: string,
			items: ListingView[]
		): HTMLElement {
			const section = sectionTmpl!.content.firstElementChild!.cloneNode(true) as HTMLElement;
			const header = section.querySelector<HTMLAnchorElement>(
				'[data-category-section-header]'
			);
			const labelEl = section.querySelector<HTMLElement>('[data-category-section-label]');
			const grid = section.querySelector<HTMLElement>('[data-category-section-grid]');
			if (header) header.href = `/iot-hub/${slug}/`;
			if (labelEl) labelEl.textContent = label;
			if (grid) {
				const variant = getCardVariant(items[0]?.itemType ?? 'WIDGET');
				grid.classList.add(`iot-hub-grid--${variant}`);
				for (const item of items) grid.appendChild(buildCardNode(item, slug));
			}
			return section;
		}

		// Group results by category in IOT_HUB_CATEGORIES priority order
		// (same logic as the build-time grouping in getStaticPaths).
		function groupResults(
			items: ListingView[]
		): Array<{ slug: string; label: string; items: ListingView[] }> {
			const byType = new Map<IotHubItemType, ListingView[]>();
			for (const it of items) {
				const cat = ITEM_TYPE_BY_TYPE.get(it.itemType as IotHubItemType);
				if (!cat) continue;
				const list = byType.get(cat.itemType) ?? [];
				list.push(it);
				byType.set(cat.itemType, list);
			}
			return IOT_HUB_CATEGORIES
				.filter((c) => byType.has(c.itemType))
				.map((c) => ({
					slug: c.slug,
					label: c.label,
					items: byType.get(c.itemType)!,
				}));
		}

		function renderResults(items: ListingView[]): void {
			if (items.length === 0) {
				showNoResults(true);
				return;
			}
			showNoResults(false);
			resultsContainer!.replaceChildren();
			for (const group of groupResults(items)) {
				resultsContainer!.appendChild(buildSectionNode(group.slug, group.label, group.items));
			}
		}

		async function refetch(opts: { resetPage?: boolean } = {}): Promise<void> {
			if (opts.resetPage) currentPage = 1;
			if (abort) abort.abort();
			abort = new AbortController();
			setLoading(true);
			const sort = getIotHubSortOption(sortId);
			const params = new URLSearchParams({
				pageSize: String(pageSize),
				page: String(currentPage - 1), // backend is 0-based
				sortProperty: sort.sortProperty,
				sortOrder: sort.sortOrder,
			});
			const trimmed = searchText.trim();
			if (trimmed) params.set('textSearch', trimmed);

			try {
				const [res, knownSlugs] = await Promise.all([
					fetch(
						`${IOT_HUB_API_URL}/api/listings/published?${params.toString()}`,
						{ signal: abort.signal }
					),
					getKnownSlugs(),
				]);
				if (!res.ok) return; // keep previous results visible
				const body = (await res.json()) as PageData<ListingView>;
				// Drop listings published after the last deploy — no static
				// detail page exists for them yet. Trade-off: a page may show
				// < pageSize items until the next rebuild.
				const items = (body.data ?? []).filter((item) => knownSlugs.has(item.slug));
				const totalPages = Math.max(1, body.totalPages || 1);
				renderResults(items);
				if (paginationNav) {
					updatePaginationDynamic(paginationNav, { currentPage, totalPages });
				}
				updateResultsCount(countEl!, body.totalElements ?? 0);
			} catch (err) {
				if (err instanceof DOMException && err.name === 'AbortError') return;
			} finally {
				setLoading(false);
			}
		}

		// On load: if `?q=` is set, kick off an immediate fetch so the URL
		// state wins over the static unfiltered SSR.
		const params = new URLSearchParams(location.search);
		const initialQ = params.get('q') ?? '';
		if (initialQ) {
			searchText = initialQ;
			void refetch({ resetPage: true });
		}

		root.addEventListener('iot-hub-search-text:change', ((e: CustomEvent) => {
			searchText = e.detail?.searchText ?? '';
			if (debounceTimer !== undefined) clearTimeout(debounceTimer);
			// setLoading kept inside refetch so the spinner only flashes once
			// the fetch is actually in flight, not on every keystroke.
			debounceTimer = window.setTimeout(() => {
				void refetch({ resetPage: true });
			}, DEBOUNCE_MS);
		}) as EventListener);

		root.addEventListener('iot-hub-sort:change', ((e: CustomEvent) => {
			sortId = e.detail?.id ?? DEFAULT_IOT_HUB_SORT_ID;
			void refetch({ resetPage: true });
		}) as EventListener);

		root.addEventListener('iot-hub-page-size:change', ((e: CustomEvent) => {
			const next = Number.parseInt(e.detail?.perPage ?? '0', 10);
			if (!Number.isFinite(next) || next <= 0) return;
			pageSize = next;
			void refetch({ resetPage: true });
		}) as EventListener);

		root.addEventListener('iot-hub-page:change', ((e: CustomEvent) => {
			const next = Number.parseInt(e.detail?.page ?? '0', 10);
			if (!Number.isFinite(next) || next <= 0) return;
			currentPage = next;
			void refetch({ resetPage: false });
		}) as EventListener);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
	document.addEventListener('astro:page-load', init);
</script>
