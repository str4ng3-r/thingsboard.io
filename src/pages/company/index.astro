---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroPhotoCarousel from '../../components/Company/HeroPhotoCarousel.astro';
import AboutSection from '../../components/Company/AboutSection.astro';
import HistorySection from '../../components/Company/HistorySection.astro';
import TimelineSection from '../../components/Company/TimelineSection.astro';
import ValuesSection from '../../components/Company/ValuesSection.astro';
import TeamSection from '../../components/Company/TeamSection.astro';
import ContactsSection from '../../components/Company/ContactsSection.astro';
---

<BaseLayout
	forceLightTheme
	title="Our Company | ThingsBoard"
	description="Learn about ThingsBoard — our story, mission, team, and values behind the world's leading open-source IoT platform."
	pageId="company"
>
	<div class="header-spacer"></div>
	<div class="company-page">
		<HeroPhotoCarousel />
		<AboutSection />
		<HistorySection />
		<TimelineSection />
		<ValuesSection />
		<TeamSection />
		<ContactsSection />
	</div>
</BaseLayout>

<style>
	.header-spacer {
		padding-top: 80px;
	}

	.company-page {
		overflow: hidden;
	}
</style>
