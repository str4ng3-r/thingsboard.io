---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/actility/samples/abeeway-trackers-thingpark-integration.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'prerequisites', text: 'Prerequisites' },
	{ depth: 2, slug: 'thingsboard-integration-setup', text: 'ThingsBoard integration setup' },
	{ depth: 3, slug: 'create-an-uplink-converter', text: 'Create an uplink converter' },
	{ depth: 3, slug: 'test-payload-decoder', text: 'Test payload decoder' },
	{ depth: 3, slug: 'create-a-downlink-converter', text: 'Create a downlink converter' },
	{ depth: 3, slug: 'create-the-integration', text: 'Create the integration' },
	{ depth: 2, slug: 'verify-device-connectivity', text: 'Verify device connectivity' },
	{ depth: 2, slug: 'configure-rule-chain', text: 'Configure rule chain' },
	{ depth: 2, slug: 'thingpark-dashboard', text: 'ThingPark dashboard' },
	{ depth: 3, slug: 'aliases', text: 'Aliases' },
	{ depth: 3, slug: 'widgets', text: 'Widgets' },
	{ depth: 2, slug: 'verify-telemetry-and-integration-events', text: 'Verify telemetry and integration events' },
	{ depth: 2, slug: 'send-downlink-messages', text: 'Send downlink messages' },
	{ depth: 3, slug: 'downlink-message-types', text: 'Downlink message types' },
	{ depth: 2, slug: 'see-also', text: 'See also' },
];
---

<StarlightPage
	frontmatter={{
		title: 'Abeeway Trackers with Actility ThingPark',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/actility/">&larr; Actility</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	// Partner sample pages use the docs page layout without a left sidebar.
	// Mirror the same layout fix as Device Library pages so the main column +
	// TOC lay out identically to real docs pages.
	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
