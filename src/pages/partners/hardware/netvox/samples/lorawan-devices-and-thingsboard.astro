---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/netvox/samples/lorawan-devices-and-thingsboard.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'register-netvox-devices-on-a-third-party-platform', text: 'Register Netvox devices on a third-party platform' },
	{ depth: 3, slug: 'create-application', text: 'Create application' },
	{ depth: 3, slug: 'register-end-device', text: 'Register end device' },
	{ depth: 3, slug: 'network-joining', text: 'Network joining' },
	{ depth: 2, slug: 'connect-the-device-to-thingsboard', text: 'Connect the device to ThingsBoard' },
	{ depth: 3, slug: 'create-integration-in-thingsboard', text: 'Create integration in ThingsBoard' },
	{ depth: 3, slug: 'check-the-device-list', text: 'Check the device list' },
	{ depth: 3, slug: 'create-dashboard', text: 'Create dashboard' },
	{ depth: 2, slug: 'netvox-devices', text: 'Netvox devices' },
	{ depth: 3, slug: 'data-converters', text: 'Data converters' },
];
---

<StarlightPage
	frontmatter={{
		title: 'Netvox LoRaWAN Devices and ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/netvox/">&larr; Netvox Technology Co., Ltd.</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	// Partner sample pages use the docs page layout without a left sidebar.
	// Mirror the same layout fix as Device Library pages so the main column +
	// TOC lay out identically to real docs pages.
	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
