---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/mokosmart/samples/lorawan-device-and-thingsboard.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'add-gateway', text: 'Add gateway' },
	{ depth: 3, slug: 'add-gateway-on-ttn', text: 'Add gateway on TTN' },
	{ depth: 3, slug: 'create-application-on-ttn', text: 'Create application on TTN' },
	{ depth: 3, slug: 'create-integration-in-thingsboard', text: 'Create integration in ThingsBoard' },
	{ depth: 2, slug: 'add-device', text: 'Add device' },
	{ depth: 2, slug: 'add-dashboard', text: 'Add dashboard' },
	{ depth: 3, slug: 'add-battery-level-widget', text: 'Add battery level widget' },
	{ depth: 3, slug: 'add-map-widget', text: 'Add map widget' },
];
---

<StarlightPage
	frontmatter={{
		title: 'MOKO SMART LoRaWAN device and ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/mokosmart/">&larr; MOKO SMART</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
