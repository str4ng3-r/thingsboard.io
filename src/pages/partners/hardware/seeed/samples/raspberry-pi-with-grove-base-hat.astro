---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/seeed/samples/raspberry-pi-with-grove-base-hat.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'prerequisites', text: 'Prerequisites' },
	{ depth: 2, slug: 'wiring-scheme', text: 'Wiring scheme' },
	{ depth: 2, slug: 'configure-the-raspberry-pi', text: 'Configure the Raspberry Pi' },
	{ depth: 2, slug: 'create-a-device-in-thingsboard', text: 'Create a device in ThingsBoard' },
	{ depth: 2, slug: 'application-source-code', text: 'Application source code' },
	{ depth: 2, slug: 'data-visualization', text: 'Data visualization' },
	{ depth: 3, slug: 'import-the-dashboard', text: 'Import the dashboard' },
	{ depth: 3, slug: 'run-the-application', text: 'Run the application' },
];
---

<StarlightPage
	frontmatter={{
		title: 'Raspberry Pi with Grove Base Hat and ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/seeed/">&larr; Seeed Studio</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	// Partner sample pages use the docs page layout without a left sidebar.
	// Mirror the same layout fix as Device Library pages so the main column +
	// TOC lay out identically to real docs pages.
	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
