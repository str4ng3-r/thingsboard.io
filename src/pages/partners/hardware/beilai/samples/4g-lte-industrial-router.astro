---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/beilai/samples/4g-lte-industrial-router.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'configure-thingsboard', text: 'Configure ThingsBoard' },
	{ depth: 2, slug: 'configure-the-router', text: 'Configure the router' },
	{ depth: 2, slug: 'verify-telemetry', text: 'Verify telemetry' },
	{ depth: 2, slug: 'create-a-dashboard', text: 'Create a dashboard' },
];
---

<StarlightPage
	frontmatter={{
		title: '4G LTE Industrial Router and ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/beilai/">&larr; Shenzhen Beilai Technology Co., Ltd.</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
