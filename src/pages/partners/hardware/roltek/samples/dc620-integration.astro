---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/roltek/samples/dc620-integration.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'create-a-device-in-thingsboard', text: 'Create a device in ThingsBoard' },
	{ depth: 2, slug: 'configure-the-dc620', text: 'Configure the DC620' },
	{ depth: 3, slug: 'mqtt-settings', text: 'MQTT settings' },
	{ depth: 3, slug: 'configure-mqtt-payload', text: 'Configure MQTT payload' },
	{ depth: 3, slug: 'add-mqtt-publisher', text: 'Add MQTT publisher' },
	{ depth: 2, slug: 'add-data-to-a-dashboard', text: 'Add data to a dashboard' },
];
---

<StarlightPage
	frontmatter={{
		title: 'Roltek DC620 Integration with ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/roltek/">&larr; Roltek</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	// Partner sample pages use the docs page layout without a left sidebar.
	// Mirror the same layout fix as Device Library pages so the main column +
	// TOC lay out identically to real docs pages.
	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
