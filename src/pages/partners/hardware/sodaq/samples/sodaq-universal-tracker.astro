---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Content from '@includes/docs/partners/hardware/sodaq/samples/sodaq-universal-tracker.mdx';
import type { MarkdownHeading } from 'astro';

const headings: MarkdownHeading[] = [
	{ depth: 2, slug: 'introduction', text: 'Introduction' },
	{ depth: 2, slug: 'prerequisites', text: 'Prerequisites' },
	{ depth: 2, slug: 'step-1-data-converter-configuration', text: 'Step 1: Data converter configuration' },
	{ depth: 2, slug: 'step-2-integration-configuration', text: 'Step 2: Integration configuration' },
	{ depth: 2, slug: 'step-3-post-telemetry-and-verify-the-integration', text: 'Step 3: Post telemetry and verify the integration' },
	{ depth: 2, slug: 'step-4-t-mobile-nb-iot-platform-callback-configuration', text: 'Step 4: T-Mobile NB-IoT platform callback configuration' },
	{ depth: 2, slug: 'step-5-check-integration-debug-events', text: 'Step 5: Check integration debug events' },
	{ depth: 2, slug: 'step-6-rule-chain-import', text: 'Step 6: Rule chain import' },
	{ depth: 2, slug: 'step-7-dashboard-import', text: 'Step 7: Dashboard import' },
	{ depth: 2, slug: 'advanced-configuration-optional', text: 'Advanced configuration (optional)' },
	{ depth: 3, slug: 'security', text: 'Security' },
	{ depth: 3, slug: 'message-flow', text: 'Message flow' },
	{ depth: 3, slug: 'create-the-tracker-alarms-rule-chain', text: 'Create the Tracker Alarms rule chain' },
	{ depth: 3, slug: 'modify-the-root-rule-chain', text: 'Modify the root rule chain' },
];
---

<StarlightPage
	frontmatter={{
		title: 'SODAQ Universal Tracker with T-Mobile NB-IoT and ThingsBoard',
		template: 'doc',
		pagefind: true,
	}}
	hasSidebar={false}
	headings={headings}
>
	<div class="partner-sample-page">
		<nav class="partner-sample-breadcrumb not-content" aria-label="Breadcrumb">
			<a href="/partners/hardware/sodaq/">&larr; SODAQ</a>
		</nav>
		<Content />
	</div>
</StarlightPage>

<style lang="scss" is:global>
	@use '../../../../../styles/variables' as *;

	// Partner sample pages use the docs page layout without a left sidebar.
	// Mirror the same layout fix as Device Library pages so the main column +
	// TOC lay out identically to real docs pages.
	:root:has(.partner-sample-page) {
		--sl-content-width: 45rem;
		--sl-content-inline-start: var(--sl-sidebar-width);
	}

	@media (min-width: 72rem) {
		:root:has(.partner-sample-page) .main-pane {
			--sl-content-margin-inline: auto 0;
			order: 1;
			width: calc(
				var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
			);
		}
	}

	@media (max-width: 50rem) {
		:root:has(.partner-sample-page) {
			--sl-content-inline-start: 0;
		}
	}

	.partner-sample-page {
		.sl-markdown-content > :first-child {
			margin-top: 0;
		}
	}

	.partner-sample-breadcrumb {
		margin-bottom: $spacing-6;
		font-size: $font-size-sm;

		a {
			color: var(--sl-color-text-accent);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	}
</style>
