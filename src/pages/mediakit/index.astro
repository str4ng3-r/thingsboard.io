---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/MediaKit/HeroSection.astro';
import LogosSection from '../../components/MediaKit/LogosSection.astro';
import ColorsSection from '../../components/MediaKit/ColorsSection.astro';
import TrademarksSection from '../../components/MediaKit/TrademarksSection.astro';
import ContactBannerSection from '../../components/MediaKit/ContactBannerSection.astro';
---

<BaseLayout
	forceLightTheme
	title="Media Kit | ThingsBoard"
	description="ThingsBoard Media Kit — company overview and official visuals all in one place."
	pageId="mediakit"
>
	<div class="header-spacer"></div>
	<div class="mediakit-overflow-guard">
	<div class="mediakit-page">
		<HeroSection />
		<LogosSection />
		<ColorsSection />
		<TrademarksSection />
		<ContactBannerSection />
	</div>
	</div>
</BaseLayout>

<style>
	.header-spacer {
		padding-top: 80px;
	}

	.mediakit-overflow-guard {
		overflow-x: hidden;
	}

	.mediakit-page {
		max-width: 1400px;
		margin: 0 auto;
		padding: 80px 20px 0;
	}
</style>