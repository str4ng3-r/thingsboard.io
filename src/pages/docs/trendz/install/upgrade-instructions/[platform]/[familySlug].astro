---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
	TRENDZ_UPGRADE_VERSIONS,
	TRENDZ_UPGRADE_FAMILIES,
	getTrendzFamilySlug,
} from '~/models/trendz-upgrade-instructions';
import TrendzUpgradeSteps from '~/components/upgrade-instructions/TrendzUpgradeSteps.astro';

type Platform = 'ubuntu' | 'centos' | 'windows' | 'docker' | 'kubernetes';

const PLATFORM_LABELS: Record<Platform, string> = {
	ubuntu: 'Ubuntu',
	centos: 'CentOS/RHEL',
	windows: 'Windows',
	docker: 'Docker',
	kubernetes: 'Kubernetes',
};

export function getStaticPaths() {
	const platforms: Platform[] = ['ubuntu', 'centos', 'windows', 'docker', 'kubernetes'];
	const paths = [];
	for (const family of TRENDZ_UPGRADE_FAMILIES) {
		const slug = getTrendzFamilySlug(family);
		for (const platform of platforms) {
			paths.push({ params: { platform, familySlug: slug }, props: { family } });
		}
	}
	return paths;
}

const { platform } = Astro.params;
const { family } = Astro.props as { family: string };

const platformLabel = PLATFORM_LABELS[platform as Platform] ?? platform;
const title = `Trendz Analytics ${platformLabel} ${family}.x Upgrade Instructions`;

const familyVersions = TRENDZ_UPGRADE_VERSIONS.filter((v) => v.family === family);

const headings: { depth: number; slug: string; text: string }[] = [];

// Add "Prepare" heading for Linux and Kubernetes platforms
if (platform === 'ubuntu' || platform === 'centos' || platform === 'kubernetes') {
	headings.push({
		depth: 2,
		slug: 'prepare-for-upgrading-trendz-analytics',
		text: 'Prepare for upgrading Trendz Analytics',
	});
}

// Add per-version headings
for (const v of familyVersions) {
	headings.push({
		depth: 2,
		slug: v.anchor,
		text: v.patch
			? `Upgrading Trendz Analytics to latest ${v.baseVersion} (${v.displayVersion})`
			: `Upgrading Trendz Analytics to ${v.displayVersion}`,
	});
}

const backUrl = '/docs/trendz/install/upgrade-instructions/';
---

<StarlightPage frontmatter={{ title, tableOfContents: true }} {headings}>
	<p><a href={backUrl}>&larr; Back to all versions</a></p>
	<TrendzUpgradeSteps platform={platform as Platform} filterFamily={family} />
</StarlightPage>
