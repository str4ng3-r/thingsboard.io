---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getDocsPrefix, Products } from '~/models/site.models';

interface Props {
	src: string;
	alt: string;
	width?: number | string;
	align?: 'left' | 'center' | 'right';
	/**
	 * Product context for inlined interactive SVGs. When provided, every
	 * `/docs/…` link inside the SVG is rewritten to `/docs/{prefix}…` so the
	 * same diagram works correctly across CE/PE/PaaS/Edge/etc. SVGs on disk
	 * carry CE paths as the source of truth (validated by lint-linkcheck).
	 */
	product?: Products;
}

const { src, alt, width, align = 'center', product } = Astro.props;

const numericWidth = typeof width === 'number' ? width : undefined;
const styleWidth = typeof width === 'string' ? width : undefined;

const styles: string[] = [];
if (styleWidth) styles.push(`max-width: ${styleWidth}`);
if (align !== 'center') styles.push(`text-align: ${align}`);
if (styleWidth && align === 'right') styles.push('margin-inline: auto 0');
else if (styleWidth && align === 'center') styles.push('margin-inline: auto');
const figureStyle = styles.length ? styles.join('; ') : undefined;

const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif,svg}',
	{ eager: true }
);

// Raw SVG sources, so diagrams with clickable <a> can be inlined.
// <img src> disables SVG interactivity in every browser, so there is no
// way to make the links work other than rendering the SVG inline.
// Lazy so Vite only reads the SVG actually referenced by this DocImage —
// eager would pull ~400 SVG source strings into the module graph even
// though only a handful contain <a> tags.
const svgRawModules = import.meta.glob<string>(
	'/src/assets/**/*.svg',
	{ query: '?raw', import: 'default' }
);

const mod = assetModules[src];
const isSvg = src.endsWith('.svg');
const rawSvg = isSvg ? await svgRawModules[src]?.() : undefined;
let interactiveSvg = rawSvg && /<a[\s>]/i.test(rawSvg) ? rawSvg : null;

// Rewrite hrefs for the current product so inline diagrams navigate within
// the same product context (CE → PE/PaaS/etc). SVG source stays CE-based.
if (interactiveSvg && product && product !== Products.CE) {
	const prefix = getDocsPrefix(product);
	interactiveSvg = interactiveSvg.replace(
		/((?:xlink:)?href=")\/docs\//g,
		`$1/docs/${prefix}`
	);
}

// Expose `alt` as the SVG's own accessible name. No `role="img"`: that role
// hides the subtree from AT, making the interactive <a> anchors unreachable
// for screen-reader users — defeats the point of inlining them. SVG's
// default graphics-document role keeps children exposed while still picking
// up `aria-label` as the accessible name.
if (interactiveSvg) {
	const escapedAlt = alt.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
	interactiveSvg = interactiveSvg.replace(/<svg\b/, `<svg aria-label="${escapedAlt}"`);
}
const optimized =
	mod && !isSvg
		? await getImage({
				src: mod.default,
				...(numericWidth ? { width: numericWidth } : {}),
				format: 'webp',
				quality: 85,
			})
		: null;
---

<figure
	class="doc-image"
	class:list={{ 'doc-image--inline-svg': !!interactiveSvg }}
	style={figureStyle}
>
	{
		interactiveSvg ? (
			<Fragment set:html={interactiveSvg} />
		) : optimized ? (
			<img
				src={optimized.src}
				alt={alt}
				width={optimized.attributes.width}
				height={optimized.attributes.height}
				loading="lazy"
				decoding="async"
			/>
		) : mod ? (
			<img src={mod.default.src} alt={alt} width={numericWidth} loading="lazy" decoding="async" />
		) : (
			<img src={src} alt={alt} width={numericWidth} loading="lazy" decoding="async" />
		)
	}
</figure>

<style>
	.doc-image {
		margin: 1.5rem 0;
		text-align: center;
	}

	.doc-image img {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
	}

	/* Inlined interactive SVGs (set:html content is not Astro-scoped). */
	.doc-image--inline-svg :global(svg) {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
	}

	:global(.doc-image-row) {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin: 1.5rem 0;
	}

	:global(.doc-image-row) .doc-image {
		flex: 1;
		min-width: 0;
		margin: 0;
	}

	@media (max-width: 640px) {
		:global(.doc-image-row) {
			flex-direction: column;
		}

		:global(.doc-image-row) .doc-image {
			max-width: 100% !important;
		}
	}
</style>
