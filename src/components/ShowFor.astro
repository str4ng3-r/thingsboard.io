---
import { Products } from '~/models/site.models';

interface Props {
	product: Products;
	show: Products[];
}

const { product, show } = Astro.props;
const visible = show.includes(product);
// Components inside this conditional slot can't rely on their own hoisted
// <script> — Astro may drop it (see config/integrations/image-gallery-lightbox.ts).
---

{visible && <slot />}
