---
import iconPrivateCloud from '~/assets/images/landings/trendz/icon-privat-cloud.svg?raw';
import iconCloud from '~/assets/images/landings/trendz/icon-cloud.svg?raw';
import iconTrendz from '~/assets/images/landings/trendz/icon-trendz.svg?raw';

const cards = [
	{
		icon: iconPrivateCloud,
		title: 'Trendz for Private Cloud',
		description:
			'Get full access to Metric Explorer, Anomaly Detection, Predictions, and more – all directly inside your ThingsBoard Private Cloud.',
		pricingHref: '/pricing/?section=thingsboard-pe-options&product=thingsboard-private-cloud',
		enableHref: '/docs/trendz/activation/private-cloud/',
	},
	{
		icon: iconCloud,
		title: 'Trendz for Public Cloud',
		description:
			'Seamlessly activate Trendz on your ThingsBoard Cloud and start exploring telemetry, building metrics, and detecting anomalies with no code.',
		pricingHref: '/pricing/?section=thingsboard-pe-options&product=thingsboard-cloud',
		enableHref: '/docs/trendz/activation/public-cloud/',
	},
	{
		icon: iconTrendz,
		title: 'Trendz for Self-Hosted',
		description:
			'Integrate the full AI-driven Trendz experience on your server. Activate your add-on and unlock analytics, predictions, anomaly detection, and more.',
		pricingHref: '/pricing/?section=thingsboard-pe-options&product=thingsboard-pe',
		enableHref: '/docs/trendz/activation/self-managed/',
	},
];
---

<section id="trendz-deployment">
	<div class="do-inner">
		<div class="do-header">
			<h2 class="do-title">How to Run Trendz for Efficient Data Analytics in IoT</h2>
			<p class="do-subtitle">
				We provide true deployment freedom designed to match your main platform license. Find the configuration that
				corresponds to your current plan below.
			</p>
		</div>

		<div class="do-cards">
			{
				cards.map((card) => (
					<div class="do-card">
						<div class="do-card-icon" set:html={card.icon} />
						<h3 class="do-card-title">{card.title}</h3>
						<p class="do-card-desc">{card.description}</p>
						<div class="do-card-actions">
							<a class="do-btn do-btn--filled" href={card.pricingHref} target="_blank" rel="noopener noreferrer">
								View Pricing
							</a>
							<a class="do-btn do-btn--outline" href={card.enableHref} target="_blank" rel="noopener noreferrer">
								Enable Trendz Add-on
							</a>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/trendz' as *;

	#trendz-deployment {
		background: #f4f8fe;
		padding: 32px 20px;
		box-sizing: border-box;

		@include trendz-up(sm) {
			padding: 60px 50px;
		}

		@include trendz-up(lg) {
			padding: 100px 50px;
		}
	}

	.do-inner {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.do-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
		text-align: center;
	}

	.do-title {
		@include trendz-h2;
		color: var(--text-text-primary, rgba(0, 0, 0, 0.87));
		margin: 0;

		@include trendz-down(xs) {
			@include trendz-h3;
		}
	}

	.do-subtitle {
		@include trendz-h5;
		color: var(--text-text-secondary, rgba(0, 0, 0, 0.76));
		max-width: 720px;
		margin: 0;

		@include trendz-down(xs) {
			@include trendz-body-s;
		}
	}

	.do-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 16px;

		@include trendz-up(lg) {
			grid-template-columns: repeat(3, 1fr);
			gap: 24px;
		}
	}

	.do-card {
		background: #fff;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 16px;
		padding: 28px 20px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
		max-width: 600px;
		width: 100%;
		margin: 0 auto;

		@include trendz-up(sm) {
			padding: 32px 24px;
		}

		@include trendz-up(lg) {
			max-width: none;
			margin: 0;
		}
	}

	.do-card-icon {
		border-radius: 24px;
		border: 1.5px solid #3e9af8;
		display: flex;
		height: 92px;
		padding: 8px 16px;
		align-items: center;
		gap: 8px;
	}

	.do-card-title {
		@include trendz-h3;
		color: var(--text-text-primary, rgba(0, 0, 0, 0.87));
		margin: 0;
		text-align: center;
	}

	.do-card-desc {
		@include trendz-body-s;
		color: var(--text-text-secondary, rgba(0, 0, 0, 0.76));
		margin: 0;
		flex: 1;
		text-align: center;
	}

	.do-card-actions {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin-top: 8px;
		align-self: stretch;
	}

	.do-btn {
		display: block;
		width: 100%;
		padding: 12px 16px;
		border-radius: 4px;
		@include trendz-body-m-medium;
		text-align: center;
		text-decoration: none;
		transition:
			background 0.2s,
			color 0.2s,
			border-color 0.2s;
		box-sizing: border-box;

		&--filled {
			background: var(--color-trendz-accent);
			color: #fff;
			border: 1.5px solid var(--color-trendz-accent);

			&:hover {
				background: var(--color-trendz-accent-hover);
				border-color: var(--color-trendz-accent-hover);
			}
		}

		&--outline {
			background: transparent;
			color: var(--color-trendz-accent);
			border: 1.5px solid var(--color-trendz-accent);

			&:hover {
				background: rgba(0, 0, 0, 0.04);
			}
		}
	}
</style>
