<section id="trendz-bottom-cta">
	<div class="cta-inner">
		<div class="cta-card">
			<h2 class="cta-title">Create your powerful IoT Analytics Solutions</h2>
			<p class="cta-subtitle">
				Try Trendz for free with the Free plan, connect it to your ThingsBoard, or submit a request and we will help you
				choose the best option.
			</p>
			<div class="cta-actions">
				<a
					class="cta-btn cta-btn--primary"
					href="/docs/trendz/activation/how-to/"
					target="_blank"
					rel="noopener noreferrer">Start for free</a
				>
				<button type="button" class="cta-btn cta-btn--secondary" data-trendz-open-modal> Contact us </button>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/trendz' as *;

	#trendz-bottom-cta {
		background: #fff;
		padding: 32px 20px;
		box-sizing: border-box;

		@include trendz-up(sm) {
			padding: 60px 50px;
		}

		@include trendz-up(lg) {
			padding: 100px 50px;
		}
	}

	.cta-inner {
		max-width: 1400px;
		margin: 0 auto;
	}

	.cta-card {
		background: var(--color-trendz-accent);
		border-radius: 24px;
		padding: 32px 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 32px;
		text-align: center;

		@include trendz-up(sm) {
			padding: 46px;
		}
	}

	.cta-title {
		@include trendz-h2;
		color: #fff;
		margin: 0;

		@include trendz-down(xs) {
			@include trendz-h4;
		}
	}

	.cta-subtitle {
		@include trendz-h5;
		color: #fff;
		margin: -16px 0 0;
		max-width: 660px;

		@include trendz-down(xs) {
			@include trendz-body-s;
			margin-top: -16px;
		}
	}

	.cta-actions {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 16px;
		width: 100%;

		@include trendz-up(sm) {
			flex-direction: row;
			justify-content: center;
			align-items: center;
			width: auto;
			gap: 32px;
		}
	}

	.cta-btn {
		display: block;
		font-size: 20px;
		font-weight: 600;
		line-height: 32px;
		letter-spacing: 0.15px;
		border-radius: 4px;
		padding: 8px 84px;
		text-align: center;
		text-decoration: none;
		cursor: pointer;
		transition:
			background 0.3s,
			color 0.3s,
			border-color 0.3s;
		border: 1.5px solid #fff;
		box-sizing: border-box;

		&--primary {
			background: #fff;
			color: var(--color-trendz-accent);

			&:hover {
				background: rgba(255, 255, 255, 0.88);
			}
		}

		&--secondary {
			background: transparent;
			color: #fff;
			font-family: inherit;

			&:hover {
				background: rgba(255, 255, 255, 0.12);
			}
		}
	}
</style>
