---
import { getImage } from 'astro:assets';
import ProjectScreenFrame from '../Services/ProjectScreenFrame.astro';
import TrendzChip from './TrendzChip.astro';
const sphereImg = await getImage({
	src: (await import('/src/assets/images/landings/trendz/sphere.png')).default,
	quality: 85,
});
---

<section id="trendz-hero">
	<div class="hero-container" style={`--sphere-url: url(${sphereImg.src})`}>
		<div id="hero-content">
			<h1 class="pe-heading fade-in-left">
				<TrendzChip label="Trendz Analytics" />
				The <span class="no-break">AI-Powered</span>
				<span class="title-break">IoT Data Analytics Workspace</span>
			</h1>
			<p class="pe-subTitle">
				Trendz Analytics is an add-on for ThingsBoard that turns telemetry into business KPIs and actionable insights.
			</p>
			<div class="btn-block">
				<div>
					<a id="Products_TA_GetADemo1" href="/products/trendz/request-demo/" class="btn-accent" data-trendz-open-modal
						>Talk to an Expert</a
					>
				</div>
				<div>
					<a
						id="Products_TA_GetStarted"
						href="/docs/trendz/activation/how-to/"
						class="btn-outline"
						target="_blank"
						rel="noopener noreferrer"
					>
						Activate Trendz in ThingsBoard
					</a>
				</div>
			</div>
		</div>

		<div class="hero-image">
			<ProjectScreenFrame fillColor="#E5EFFF" borderRadius="8px" class="hero-screen-frame">
				<video
					width="857"
					height="426"
					autoplay
					muted
					loop
					playsinline
					preload="auto"
					aria-label="Trendz Analytics dashboard demo"
				>
					<source src="/products/trendz/hero-video.mp4" type="video/mp4" />
				</video>
			</ProjectScreenFrame>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/trendz' as *;
	#trendz-hero {
		width: 100%;
		height: auto;
		padding-top: 100px;
		background-color: #f4f8fe;
		box-sizing: border-box;

		.hero-container {
			height: 100%;
			display: flex;
			flex-direction: column;
			position: relative;
			margin: 0 20px;

			#hero-content {
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
				text-align: initial;
				flex: 1;
				z-index: 1;

				:global(.trendz-chip) {
					display: flex;
					width: fit-content;
					margin-bottom: 12px;
				}

				.title-break {
					display: block;
				}

				.no-break {
					white-space: nowrap;
				}

				.pe-heading {
					@include trendz-h1-responsive;
					color: var(--color-trendz-text-primary);
					margin: 0 0 10px;
				}

				.pe-subTitle {
					@include trendz-h5-responsive;
					color: var(--color-trendz-text-secondary);
					margin: 0 0 24px;
				}

				.btn-block {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 10px;
					width: 100%;
					flex-direction: column;

					div {
						width: 100%;
					}
				}
			}

			.hero-image {
				display: flex;
				align-items: center;
				width: 100%;
				position: relative;
				visibility: visible;
				padding: 5% 0 10% 0;
				box-sizing: border-box;

				:global(video) {
					border: 1px solid #e6e6e6;
					box-shadow:
						0 0 12px 0 rgba(83, 92, 115, 0.02),
						0 24px 36px 0 rgba(83, 92, 115, 0.07);
				}
			}

			.sphere-icon {
				position: absolute;
				opacity: 0;
				background: var(--sphere-url) no-repeat center / contain;
				animation-duration: 1.2s;
				animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
				animation-fill-mode: forwards;
			}

			#upper-icon-left {
				display: block;
				width: 100px;
				height: 100px;
				top: 50%;
				left: -70px;
				animation-name: fromRight;
			}

			#upper-icon-center {
				display: block;
				animation-name: fromTopLeft;
			}

			#upper-icon-right {
				display: block;
				width: 100px;
				height: 100px;
				right: 0;
				top: 10%;
				animation-name: fromBottomRight;
			}

			#down-icon-left {
				display: none;
				animation-name: fromBottomLeft;
			}

			#down-icon-right {
				display: none;
				animation-name: fromBottomRight;
			}
		}
	}

	.btn-accent {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 4px;
		height: 48px;
		min-width: 88px;
		width: 100%;
		padding: 8px 48px;
		background: var(--color-trendz-accent);
		border-radius: 6px;
		@include trendz-body-m-medium;
		color: #ffffff;
		border: 1px solid var(--color-trendz-accent);
		text-decoration: none;
		transition: 0.3s;
		box-sizing: border-box;

		&:hover {
			background-color: var(--color-trendz-accent-hover);
			border-color: var(--color-trendz-accent-hover);
			color: #ffffff;
		}
	}

	.btn-outline {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 4px;
		height: 48px;
		min-width: 88px;
		width: 100%;
		padding: 8px 48px;
		box-sizing: border-box;
		cursor: pointer;
		border: 1px solid var(--color-trendz-accent);
		border-radius: 6px;
		background-color: transparent;
		transition: 0.6s;
		color: var(--color-trendz-accent);
		text-decoration: none;

		&:hover {
			background: var(--color-trendz-accent);
			color: #ffffff;
		}
	}

	// Heading slides in from left on page load (matches Animate.css fadeInLeft)
	.fade-in-left {
		opacity: 0;
		animation-name: fadeInLeft;
		animation-duration: 1s;
		animation-fill-mode: both;
	}

	// 600px+ — hero image visible below content, buttons go horizontal
	@include trendz-up(sm) {
		#trendz-hero .hero-container {
			margin: 0 40px;

			#hero-content {
				flex: none;
				height: auto;

				.pe-subTitle {
					margin-bottom: 40px;
				}

				.btn-block {
					padding: 0;
					flex-direction: row;
					width: unset;

					div {
						width: unset;
					}
				}
			}

			.hero-image {
				width: 100%;
			}

			#upper-icon-left {
				width: 90px;
				height: 90px;
				top: 30%;
				left: 50%;
			}

			#upper-icon-right {
				width: 90px;
				height: 90px;
				top: 25%;
			}

			#down-icon-left {
				display: block;
				width: 120px;
				height: 120px;
				bottom: 22%;
				right: 10%;
			}
		}

		.btn-accent {
			width: auto;
		}

		.btn-outline {
			width: auto;
		}
	}

	// 960px+ — max-width container, larger fonts, more icons appear
	@include trendz-up(md) {
		#trendz-hero .hero-container {
			margin: auto;
			width: calc(100% - 100px);
			max-width: 1200px;

			.hero-image {
				padding: 12% 4% 10% 4%;
			}

			#upper-icon-left {
				width: 100px;
				height: 100px;
				left: 25%;
				top: 20%;
			}

			#upper-icon-center {
				width: 90px;
				height: 90px;
				top: 18%;
				left: 54%;
			}

			#upper-icon-right {
				top: 25%;
				right: -5%;
				width: 100px;
				height: 100px;
			}

			#down-icon-left {
				width: 200px;
				height: 200px;
				bottom: 15%;
				left: 40%;
			}

			#down-icon-right {
				display: block;
				width: 200px;
				height: 200px;
				bottom: 20%;
				right: 0;
			}
		}
	}

	// 1280px+ — side-by-side layout, max container width
	@include trendz-up(lg) {
		#trendz-hero {
			height: 100vh;
			overflow: hidden;
			padding-top: 80px;
		}

		#trendz-hero .hero-container {
			max-width: 1400px;
			flex-direction: row;

			#hero-content {
				flex: 1 1 50%;
				height: 100%;

				.pe-heading {
					padding-right: 10%;
				}
			}

			.hero-image {
				flex: 1 1 50%;
				height: 100%;
				padding: 0 0 0 40px;
			}

			#down-icon-left {
				bottom: 5px;
			}
		}
	}

	@keyframes fadeInLeft {
		from {
			opacity: 0;
			transform: translate3d(-100%, 0, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes fromTopLeft {
		from {
			opacity: 0;
			transform: translate(-200px, -200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomRight {
		from {
			opacity: 0;
			transform: translate(200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomLeft {
		from {
			opacity: 0;
			transform: translate(-200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromRight {
		from {
			opacity: 0;
			transform: translateX(-200px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
</style>
