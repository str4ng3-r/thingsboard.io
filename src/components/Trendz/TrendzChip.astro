---
interface Props {
	label: string;
	color?: string;
	bg?: string;
	tag?: 'h1' | 'h2' | 'h3' | 'p' | 'span';
}

const { label, color = 'var(--color-trendz-accent)', bg = 'transparent', tag: Tag = 'span' } = Astro.props;
---

<Tag class="trendz-chip" style={`--chip-color: ${color}; --chip-bg: ${bg}`}>
	<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
		<circle cx="5" cy="5" r="5" fill="var(--chip-color)"></circle>
	</svg>
	{label}
</Tag>

<style lang="scss">
	.trendz-chip {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 5px 16px;
		border: 1px solid var(--chip-color);
		border-radius: 999px;
		background: var(--chip-bg);
		color: var(--chip-color);
		font-size: 14px;
		font-weight: 500;
		line-height: 1.5;
	}
</style>
