---
import type { ComparisonRow } from '@data/use-cases/types.ts';

interface Props {
	title: string;
	rows: ComparisonRow[];
}

const { title, rows } = Astro.props;
---

<section class="uc-comparison uc-section-padding">
	<h2>{title}</h2>

	{/* Desktop table */}
	<table class="uc-comparison__table">
		<thead>
			<tr>
				<th class="uc-comparison__th-criteria"></th>
				<th>High-performance</th>
				<th>Traditional</th>
			</tr>
		</thead>
		<tbody>
			{
				rows.map((row, i) => (
					<tr class={i % 2 === 0 ? 'uc-comparison__row--alt' : ''}>
						<td class="uc-comparison__td-criteria">{row.criteria}</td>
						<td>{row.highPerformance}</td>
						<td>{row.traditional}</td>
					</tr>
				))
			}
		</tbody>
	</table>

	{/* Mobile stacked */}
	<div class="uc-comparison__mobile">
		<div class="uc-comparison__mobile-header">
			<span>High-performance</span>
			<span>Traditional</span>
		</div>
		{
			rows.map((row) => (
				<div class="uc-comparison__card">
					<p class="uc-comparison__card-label">{row.criteria}</p>
					<div class="uc-comparison__card-values">
						<div>{row.highPerformance}</div>
						<div>{row.traditional}</div>
					</div>
				</div>
			))
		}
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-comparison {
		> h2 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-10;
		}
	}

	// ── Desktop table ──
	.uc-comparison__table {
		width: 100%;
		border-collapse: separate;
		border-spacing: 0;
		border: 1px solid var(--color-border-light);
		border-radius: 12px;
		overflow: hidden;
		table-layout: fixed;

		@include media-down(lg) {
			display: none;
		}

		thead tr {
			background: $color-text-primary;
		}

		th {
			@include text-table-header;
			padding: 16px 24px;
			text-align: left;
			color: $color-white;
			border-left: 1px solid rgba(255, 255, 255, 0.15);

			&:first-child {
				border-left: none;
			}
		}

		.uc-comparison__th-criteria {
			width: 35%;
		}

		td {
			@include text-table-cell;
			padding: 16px 24px;
			color: var(--color-text-secondary);
			border-left: 1px solid var(--color-border-light);
			border-top: 1px solid var(--color-border-light);

			&:first-child {
				border-left: none;
			}
		}

		.uc-comparison__td-criteria {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
		}

		.uc-comparison__row--alt {
			background: var(--color-bg-light);
		}
	}

	// ── Mobile stacked ──
	.uc-comparison__mobile {
		display: none;

		@include media-down(lg) {
			display: block;
		}
	}

	.uc-comparison__mobile-header {
		display: flex;
		gap: $spacing-4;
		margin-bottom: $spacing-4;

		span {
			@include text-table-header;
			flex: 1;
			font-size: $font-size-base;
			color: $color-white;
			background: $color-text-primary;
			border-radius: $radius-lg;
			padding: 10px $spacing-4;
			text-align: center;
		}
	}

	.uc-comparison__card {
		margin-bottom: $spacing-3;
	}

	.uc-comparison__card-label {
		@include text-s;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0 0 $spacing-2;
	}

	.uc-comparison__card-values {
		display: flex;
		gap: $spacing-4;

		div {
			@include text-s;
			flex: 1;
			padding: 10px $spacing-4;
			color: var(--color-text-secondary);
			background: var(--color-bg-light);
			border-radius: $radius-lg;
			text-align: center;
		}
	}
</style>
