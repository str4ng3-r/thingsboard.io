---
import { Icon } from 'astro-icon/components';
import type { FeedbackEntry } from '../../data/clients-feedback/types';

interface Props {
	entry: FeedbackEntry;
	category: string;
	duplicate?: boolean;
}

const { entry, category, duplicate = false } = Astro.props;
const isLong = entry.tagline.length + entry.text.reduce((s, p) => s + p.length, 0) > 600;
---

<article class:list={['cf-card', { 'cf-dupe': duplicate }]} data-category={category}>
	<div class="cf-card-header">
		<div class="cf-card-author">
			{entry.authorImage ? (
				<img
					class="cf-card-avatar"
					src={entry.authorImage}
					alt={entry.author}
					width="64"
					height="64"
					loading="lazy"
				/>
			) : (
				<div class="cf-card-avatar cf-card-avatar--placeholder">
					{entry.author.charAt(0)}
				</div>
			)}
			<div class="cf-card-author-info">
				<p class="cf-card-name">{entry.author}</p>
				{entry.position && <p class="cf-card-position">{entry.position}</p>}
			</div>
		</div>
		<div class="cf-card-company">
			{entry.link ? (
				<a href={entry.link} target="_blank" rel="noopener noreferrer">
					<img
						src={entry.companyImage}
						alt={entry.companyName}
						width={entry.companyImageWidth}
						height={entry.companyImageHeight}
						loading="lazy"
					/>
				</a>
			) : (
				<img
					src={entry.companyImage}
					alt={entry.companyName}
					width={entry.companyImageWidth}
					height={entry.companyImageHeight}
					loading="lazy"
				/>
			)}
		</div>
	</div>
	<div class:list={['cf-card-body', { 'cf-card-body--clamped': isLong }]}>
		<p class="cf-card-tagline">{entry.tagline}</p>
		{entry.text.map((paragraph) => (
			<p class="cf-card-text">{paragraph}</p>
		))}
	</div>
	{(isLong || entry.caseStudySlug) && (
		<div class="cf-card-actions">
			{isLong && (
				<button type="button" class="cf-read-more">
					<span class="cf-read-more-text">Read more</span>
					<Icon name="fa-solid:chevron-down" class="cf-read-more-icon" />
				</button>
			)}
			{entry.caseStudySlug && (
				<a href={`/case-studies/${entry.caseStudySlug}/`} class="cf-case-study-link" target="_blank">
					<Icon name="fa-solid:book-open" class="cf-cs-icon" />
					Case study
					<Icon name="fa-solid:arrow-right" class="cf-cs-arrow" />
				</a>
			)}
		</div>
	)}
</article>
