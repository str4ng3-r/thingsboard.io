---
import ImageGallery from './ImageGallery.astro';
import { Products } from '~/models/site.models';

interface ImageItem {
	/** Base path without product suffix, e.g. /src/assets/images/guide/step-1.png */
	src: string;
	alt: string;
	caption?: string;
	/** If set, this image is only included when the current product is in the list. */
	products?: Products[];
}

interface Props {
	images: ImageItem[];
	product: Products;
}

/**
 * Maps each product to the filename suffix inserted before the extension.
 * Example: src="/src/assets/images/foo.png" + product=PE → "/src/assets/images/foo-pe.png"
 */
const productSuffix: Record<Products, string> = {
	[Products.CE]: 'ce',
	[Products.PE]: 'pe',
	[Products.PASS]: 'paas',
	[Products.PASS_EU]: 'paas-eu',
	[Products.EDGE]: 'edge',
	[Products.EDGE_PE]: 'edge-pe',
	[Products.GW]: 'gw',
	[Products.LICENSE]: 'license',
	[Products.TRENDZ]: 'trendz',
	[Products.MOBILE]: 'mobile',
	[Products.MOBILE_PE]: 'mobile-pe',
	[Products.TBMQ]: 'tbmq',
	[Products.TBMQ_PE]: 'tbmq-pe',
};

const { images, product } = Astro.props;
const suffix = productSuffix[product];

const resolved = images
	.filter(({ products }) => !products || products.includes(product))
	.map(({ src, alt, caption }) => {
		const dotIndex = src.lastIndexOf('.');
		if (dotIndex === -1)
			throw new Error(`MultiProductImageGallery: src has no extension: "${src}"`);
		return {
			src: `${src.slice(0, dotIndex)}-${suffix}${src.slice(dotIndex)}`,
			alt,
			caption,
		};
	});
---

<ImageGallery images={resolved} />
