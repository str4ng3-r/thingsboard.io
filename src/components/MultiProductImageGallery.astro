---
import ImageGallery from './ImageGallery.astro';
import type { Products } from '~/models/site.models';

interface ImageItem {
	/** Base path without product suffix, e.g. /src/assets/images/guide/step-1.png */
	src: string;
	alt: string;
	caption?: string;
	/** If set, this image is only included when the current product is in the list. */
	products?: Products[];
}

interface Props {
	images: ImageItem[];
	product: Products;
}

const { images, product } = Astro.props;
---

<ImageGallery images={images} product={product} />
