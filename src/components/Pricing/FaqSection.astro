---
import type { FaqCategory } from '@data/pricing/types.ts';
import { buildFaqPageSchema, serializeJsonLd } from '@util/faq-schema';
import FaqItem from '@components/Pricing/FaqItem.astro';

// Self-contained FAQ section: markup, styles, and behavior (accordion, category
// tabs, "Load more", copy-link, hash deep-link) all live here. Page scripts may
// still target the `.faq-*` markup contract (the pricing page activates its
// product tabs around it and calls `window.__tbFaqOpen`), so keep the class
// names / data attributes stable, or update those consumers too.

interface Props {
	contextId: string;
	categories: FaqCategory[];
	/** Number of items visible per category before "Load more" (default: 6) */
	visibleCount?: number;
	/** Push `faq_*` events to the GTM dataLayer on interaction (marketing-owned). */
	analytics?: boolean;
	/** Emit a schema.org FAQPage block for this section. At most one per page. */
	jsonLd?: boolean;
}

const { contextId, categories, visibleCount = 6, analytics = false, jsonLd = false } = Astro.props;
---

<div
	class={`faq-section ${categories.length > 1 ? 'faq-section--with-sidebar' : ''}`}
	data-faq-context={contextId}
	data-faq-analytics={analytics ? '' : undefined}
>
	{categories.length > 1 && (
		<div class="faq-cat-sidebar">
			{categories.map((cat, i) => (
				<button
					type="button"
					class={`faq-cat-tab ${i === 0 ? 'active' : ''}`}
					aria-current={i === 0 ? 'true' : 'false'}
					data-faq-cat={cat.id}
				>
					{cat.label}
				</button>
			))}
		</div>
	)}

	<div class="faq-content-area">
		{categories.map((cat, i) => {
			const visible = cat.items.slice(0, visibleCount);
			const overflow = cat.items.slice(visibleCount);
			return (
				<div
					class={`faq-category-content ${i === 0 ? 'active' : ''}`}
					data-faq-cat-content={cat.id}
				>
					{visible.map((item) => <FaqItem item={item} />)}

					{overflow.length > 0 && (
						<button type="button" class="faq-load-more">
							Load more FAQ
						</button>
					)}

					{overflow.map((item) => <FaqItem item={item} hidden />)}
				</div>
			);
		})}
	</div>
</div>

{jsonLd && (
	<script
		type="application/ld+json"
		set:html={serializeJsonLd(buildFaqPageSchema(categories))}
		is:inline
	/>
)}

<script>
	// Runs once per page (Astro dedupes the bundled module) and drives every
	// `.faq-section` instance via document-level delegation — the pricing page
	// renders eight at once. All branches require a `.faq-section` ancestor:
	// other pages (partners, Trendz) reuse `.faq-*` class names with their own
	// incompatible markup and must stay untouched.

	declare global {
		interface Window {
			/** Open + scroll to a FAQ item by id (used by the pricing page). */
			__tbFaqOpen?: (faqId: string) => void;
		}
	}

	const trackFaq = (event: string, faqId: string, origin: Element): void => {
		// Marketing owns the GTM triggers + GA4 tags for these events; only
		// sections that opt in via the `analytics` prop push them.
		if (origin.closest('.faq-section[data-faq-analytics]')) {
			window.dataLayer?.push({ event, faq_node_id: faqId });
		}
	};

	const copyFaqLink = (copyLink: HTMLElement): void => {
		const faqId = copyLink.dataset.faqId;
		if (!faqId?.trim()) return;
		trackFaq('faq_copy_link', faqId, copyLink);
		const url = new URL(window.location.href);
		url.hash = faqId;
		navigator.clipboard
			.writeText(url.toString())
			.then(() => {
				copyLink.classList.add('copied');
				setTimeout(() => copyLink.classList.remove('copied'), 2000);
			})
			.catch(() => {});
	};

	const activateCategoryTab = (section: Element, catId: string | undefined): void => {
		if (!catId) return;
		section.querySelectorAll<HTMLElement>('.faq-cat-tab').forEach((tab) => {
			const isActive = tab.dataset.faqCat === catId;
			tab.classList.toggle('active', isActive);
			tab.setAttribute('aria-current', isActive ? 'true' : 'false');
		});
		section
			.querySelectorAll<HTMLElement>('.faq-category-content')
			.forEach((c) => c.classList.toggle('active', c.dataset.faqCatContent === catId));
	};

	const setExpanded = (item: Element, expanded: boolean): void => {
		item.classList.toggle('expanded', expanded);
		item.querySelector('.faq-question-toggle')?.setAttribute('aria-expanded', String(expanded));
	};

	const revealCategoryOverflow = (content: Element): void => {
		content
			.querySelectorAll('.faq-item--hidden')
			.forEach((el) => el.classList.remove('faq-item--hidden'));
		content.querySelector('.faq-load-more')?.classList.add('faq-load-more--used');
	};

	const openFaqItem = (faqId: string): void => {
		const item = document.getElementById(faqId);
		if (!item?.classList.contains('faq-item')) return;
		const section = item.closest('.faq-section');
		const content = item.closest<HTMLElement>('.faq-category-content');
		if (!section || !content) return;
		activateCategoryTab(section, content.dataset.faqCatContent);
		if (item.classList.contains('faq-item--hidden')) revealCategoryOverflow(content);
		if (!item.classList.contains('expanded')) {
			setExpanded(item, true);
			trackFaq('faq_node_interaction', faqId, item);
		}
		// Let the expand animation start so centering lands on the final layout.
		setTimeout(() => item.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
	};
	window.__tbFaqOpen = openFaqItem;

	document.addEventListener('click', (e) => {
		// `e.target` can be a non-Element (e.g. a Text node); `.closest()` only
		// exists on Element, so bail out otherwise.
		if (!(e.target instanceof Element)) return;
		const target = e.target;

		// Every interactive control below lives inside a `.faq-section`. Enforce
		// that invariant once here — so no branch has to re-check it, and a
		// future branch can't forget to (which would let clicks in an unrelated
		// `.faq-*` implementation leak into this handler).
		const section = target.closest('.faq-section');
		if (!section) return;

		const copyLink = target.closest<HTMLElement>('.faq-copy-link');
		if (copyLink) {
			copyFaqLink(copyLink);
			return;
		}

		const toggle = target.closest<HTMLElement>('.faq-question-toggle');
		if (toggle) {
			const item = toggle.closest('.faq-item');
			if (item) {
				const nowExpanded = !item.classList.contains('expanded');
				setExpanded(item, nowExpanded);
				// Track opens only (not collapses).
				if (nowExpanded && item.id) trackFaq('faq_node_interaction', item.id, item);
			}
			return;
		}

		const loadMore = target.closest<HTMLElement>('.faq-load-more');
		if (loadMore) {
			const content = loadMore.closest('.faq-category-content');
			if (content) revealCategoryOverflow(content);
			return;
		}

		const catTab = target.closest<HTMLElement>('.faq-cat-tab');
		if (catTab) {
			activateCategoryTab(section, catTab.dataset.faqCat);
		}
	});

	// Deep-link: open the FAQ item referenced by the URL hash. Deferred to idle
	// (bounded — a late scrollIntoView is jarring) so the walk never blocks
	// first paint. Skips items a page script already opened via __tbFaqOpen.
	const performHashWalk = (): void => {
		const hash = window.location.hash.slice(1);
		if (!hash) return;
		const item = document.getElementById(hash);
		if (!item?.classList.contains('faq-item') || !item.closest('.faq-section')) return;
		if (item.classList.contains('expanded')) return;
		openFaqItem(hash);
	};
	// Only deep-link visits need the walk at all — skip scheduling (and the
	// deferred scroll jump) entirely when there's no hash.
	if (window.location.hash) {
		if ('requestIdleCallback' in window) {
			requestIdleCallback(performHashWalk, { timeout: 500 });
		} else {
			setTimeout(performHashWalk, 200);
		}
	}
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.faq-section {
		margin-top: $spacing-8;

		&--with-sidebar {
			display: grid;
			grid-template-columns: 280px 1fr;
			gap: $spacing-10;
			align-items: start;

			@include media-down(md) {
				grid-template-columns: 1fr;
				gap: $spacing-6;
			}
		}
	}

	// ─── Category sidebar (vertical) ───
	.faq-cat-sidebar {
		display: flex;
		flex-direction: column;
		gap: $spacing-1;
		position: sticky;
		top: $spacing-8;

		@include media-down(md) {
			position: static;
			flex-direction: row;
			flex-wrap: wrap;
			gap: $spacing-2;
		}
	}

	.faq-cat-tab {
		padding: $spacing-3 $spacing-4;
		font-size: $font-size-base;
		font-weight: $font-weight-normal;
		color: var(--color-text-secondary);
		background: transparent;
		border: none;
		border-left: 3px solid transparent;
		border-radius: 0;
		cursor: pointer;
		text-align: left;
		transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
		line-height: 1.5;

		@include media-down(md) {
			font-size: $font-size-sm;
			padding: $spacing-2 $spacing-3;
			border-left: none;
			border-bottom: 2px solid transparent;
		}

		&:hover {
			color: var(--color-text);
		}

		&.active {
			color: var(--color-text);
			font-weight: $font-weight-semibold;
			border-left-color: var(--color-primary);
			background: var(--color-bg-surface);

			@include media-down(md) {
				border-left-color: transparent;
				border-bottom-color: var(--color-primary);
			}
		}
	}

	// ─── Content ───
	.faq-content-area {
		min-width: 0;
	}

	.faq-category-content {
		display: none;
		&.active { display: block; }
	}

	// ─── FAQ item — card-style with white background ───
	.faq-item {
		background: var(--color-bg);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
		margin-bottom: $spacing-2;

		&--hidden {
			display: none;
		}

		&.expanded {
			border-color: var(--color-primary);

			.faq-chevron {
				transform: rotate(180deg);
			}
		}
	}

	// ─── Question row ───
	// The row is a plain div; the heading wraps ONLY the toggle so its
	// accessible name is just the question. The toggle's stretched ::after
	// overlay makes the whole row clickable while the copy-link stays a real
	// sibling button — no interactive nesting.
	.faq-question {
		position: relative;
		display: flex;
		align-items: center;
		gap: $spacing-4;
		margin: 0;
		padding: $spacing-4 $spacing-5;
		font-size: $font-size-base;
		font-weight: $font-weight-medium;
		line-height: 1.5;
		color: var(--color-text);
		cursor: pointer;

		&:hover .faq-question-toggle {
			color: var(--color-primary);
		}
	}

	.faq-question-heading {
		flex: 1;
		min-width: 0;
		margin: 0;
		font: inherit;
	}

	.faq-question-toggle {
		width: 100%;
		padding: 0;
		border: none;
		background: none;
		font: inherit;
		color: inherit;
		text-align: left;
		cursor: pointer;
		transition: color 0.15s ease;

		// Stretch the hit area over the whole question row.
		&::after {
			content: '';
			position: absolute;
			inset: 0;
		}

		&:focus-visible {
			outline: none;

			&::after {
				outline: 2px solid var(--color-primary);
				outline-offset: -2px;
				border-radius: $radius-lg;
			}
		}
	}

	// Drawn as CSS masks so ~500 FAQ rows share one icon definition instead of
	// one inline SVG each; `currentColor` keeps the existing theming. One
	// variable per icon — mask and -webkit-mask must stay identical.
	$faq-chevron-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='none' stroke='black' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m6 9l6 6l6-6'/></svg>");
	$faq-link-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='none' stroke='black' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m9 15l6-6m-4-3l.463-.536a5 5 0 0 1 7.071 7.072L18 13m-5 5l-.397.534a5.07 5.07 0 0 1-7.127 0a4.97 4.97 0 0 1 0-7.071L6 11'/></svg>");

	.faq-chevron {
		display: block;
		width: 18px;
		height: 18px;
		color: var(--color-text-secondary);
		background-color: currentColor;
		mask: $faq-chevron-icon no-repeat center / contain;
		-webkit-mask: $faq-chevron-icon no-repeat center / contain;
		flex-shrink: 0;
		// Clicks fall through to the toggle's stretched hit-area overlay.
		pointer-events: none;
		transition: transform 0.25s ease;
	}

	// ─── Copy link (right rail, before the chevron) ───
	.faq-copy-link {
		position: relative;
		// Above the toggle's stretched hit-area overlay.
		z-index: 1;
		display: inline-flex;
		flex-shrink: 0;
		padding: 0;
		border: none;
		background: none;
		cursor: pointer;
		opacity: 0;
		// Hidden until revealed (hover/focus), and non-interactive while hidden:
		// it sits above the toggle's hit-area in the right rail, so an invisible
		// tap target here would silently copy a link the user never sees instead
		// of expanding the row. Coarse pointers (no hover) get a persistent
		// visible affordance instead — see the @media (pointer: coarse) block.
		pointer-events: none;
		color: var(--color-primary);
		transition:
			opacity 0.15s ease,
			color 0.15s ease;

		// The link glyph, masked from a shared definition (same reason as
		// .faq-chevron). The tooltip already occupies ::after.
		&::before {
			content: '';
			display: block;
			width: 14px;
			height: 14px;
			background-color: currentColor;
			mask: $faq-link-icon no-repeat center / contain;
			-webkit-mask: $faq-link-icon no-repeat center / contain;
		}

		.faq-question:hover & {
			opacity: 0.6;
			pointer-events: auto;
		}

		&:hover {
			opacity: 1 !important;
		}

		&:focus-visible {
			opacity: 1;
			pointer-events: auto;
			outline: 2px solid currentColor;
			outline-offset: 2px;
			border-radius: 2px;
		}

		// Touch/coarse pointers have no hover to reveal the button, so show it
		// persistently and keep it interactive. Being visible, it now reads as
		// its own control rather than an invisible trap beside the chevron.
		@media (pointer: coarse) {
			opacity: 0.6;
			pointer-events: auto;
		}

		// Tooltip
		&::after {
			content: 'Copy link';
			position: absolute;
			bottom: calc(100% + 6px);
			left: 50%;
			transform: translateX(-50%);
			padding: 4px 8px;
			background: var(--color-text);
			color: var(--color-bg-surface);
			font-size: 11px;
			font-weight: $font-weight-medium;
			white-space: nowrap;
			border-radius: $radius-sm;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.15s ease;
		}

		&:hover::after {
			opacity: 1;
		}

		// Copied state
		&.copied {
			opacity: 1;
			color: var(--color-success);

			&::after {
				content: 'Copied!';
				opacity: 1;
				background: var(--color-success);
			}
		}
	}

	// Forced-colors palettes override background-color in ways that can blank
	// mask-drawn glyphs (inline SVGs used to get forced stroke colors); pin
	// the icons to the system text color so they stay visible.
	@media (forced-colors: active) {
		.faq-chevron,
		.faq-copy-link::before {
			background-color: CanvasText;
		}
	}

	// ─── Answer (smooth expand via grid trick) ───
	.faq-answer {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.25s ease;

		.faq-item.expanded & {
			grid-template-rows: 1fr;
		}
	}

	// This div clips everything — padding/border must be INSIDE it
	.faq-answer-overflow {
		overflow: hidden;
	}

	.faq-answer-content {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-text);

		& *:not(a):not(strong):not(b) {
			font-size: inherit !important;
			line-height: inherit !important;
			color: inherit !important;
		}
		border-top: 1px solid var(--sl-color-gray-5);
		margin: 0 $spacing-5;
		padding: $spacing-4 0 $spacing-5;

		a {
			color: var(--color-primary);
			text-decoration: none;
			&:hover { text-decoration: underline; }
		}

		ul {
			list-style: disc !important;
			list-style-position: outside;
			padding-left: $spacing-6;
			margin: $spacing-2 0;
		}

		ol {
			list-style: decimal !important;
			list-style-position: outside;
			padding-left: $spacing-6;
			margin: $spacing-2 0;
		}

		li {
			margin-bottom: $spacing-1;
			display: list-item;
			list-style: inherit !important;
		}

		strong, b {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
		}

		em, i {
			font-style: italic;
		}

		p {
			margin: $spacing-2 0;
			&:first-child { margin-top: 0; }
		}
	}

	// ─── Load more ───
	.faq-load-more {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: $spacing-3;
		margin: $spacing-2 0;
		border: 1px dashed var(--sl-color-gray-5);
		border-radius: $radius-lg;
		background: none;
		cursor: pointer;
		color: var(--color-primary);
		font-size: $font-size-sm;
		font-weight: $font-weight-semibold;
		transition: background-color 0.15s ease, border-color 0.15s ease;

		&:hover {
			background: var(--color-bg-light);
			border-color: var(--color-primary);
		}

		&.faq-load-more--used {
			display: none;
		}
	}
</style>
