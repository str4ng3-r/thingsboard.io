---
import type { FaqCategory } from '@data/pricing/types.ts';

// This `.faq-*` markup contract is driven by two separate scripts: the pricing
// page's own inline script, and `@components/IotHub/iot-hub-faq.ts` for IoT Hub
// pages. Keep the class names / data attributes stable, or update both.

interface Props {
	contextId: string;
	categories: FaqCategory[];
	/** Number of items visible per category before "Load more" (default: 6) */
	visibleCount?: number;
}

const { contextId, categories, visibleCount = 6 } = Astro.props;
---

<div class={`faq-section ${categories.length > 1 ? 'faq-section--with-sidebar' : ''}`} data-faq-context={contextId}>
	{categories.length > 1 && (
		<div class="faq-cat-sidebar">
			{categories.map((cat, i) => (
				<button
					type="button"
					class={`faq-cat-tab ${i === 0 ? 'active' : ''}`}
					data-faq-cat={cat.id}
				>
					{cat.label}
				</button>
			))}
		</div>
	)}

	<div class="faq-content-area">
		{categories.map((cat, i) => {
			const visible = cat.items.slice(0, visibleCount);
			const overflow = cat.items.slice(visibleCount);
			return (
				<div
					class={`faq-category-content ${i === 0 ? 'active' : ''}`}
					data-faq-cat-content={cat.id}
				>
					{visible.map((item) => (
						<div class="faq-item" id={item.id}>
							<button type="button" class="faq-question" aria-expanded="false">
								<h3 class="faq-question-text">{item.question}
									<span class="faq-copy-link" data-faq-id={item.id} role="button" tabindex="0" aria-label={`Copy link to: ${item.question}`}></span>
								</h3>
								<span class="faq-chevron" aria-hidden="true"></span>
							</button>
							<div class="faq-answer">
								<div class="faq-answer-overflow">
									<div class="faq-answer-content" set:html={item.answer} />
								</div>
							</div>
						</div>
					))}

					{overflow.length > 0 && (
						<button type="button" class="faq-load-more">
							Load more FAQ
						</button>
					)}

					{overflow.map((item) => (
						<div class="faq-item faq-item--hidden" id={item.id}>
							<button type="button" class="faq-question" aria-expanded="false">
								<h3 class="faq-question-text">{item.question}
									<span class="faq-copy-link" data-faq-id={item.id} role="button" tabindex="0" aria-label={`Copy link to: ${item.question}`}></span>
								</h3>
								<span class="faq-chevron" aria-hidden="true"></span>
							</button>
							<div class="faq-answer">
								<div class="faq-answer-overflow">
									<div class="faq-answer-content" set:html={item.answer} />
								</div>
							</div>
						</div>
					))}
				</div>
			);
		})}
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.faq-section {
		margin-top: $spacing-8;

		&--with-sidebar {
			display: grid;
			grid-template-columns: 280px 1fr;
			gap: $spacing-10;
			align-items: start;

			@include media-down(md) {
				grid-template-columns: 1fr;
				gap: $spacing-6;
			}
		}
	}

	// ─── Category sidebar (vertical) ───
	.faq-cat-sidebar {
		display: flex;
		flex-direction: column;
		gap: $spacing-1;
		position: sticky;
		top: $spacing-8;

		@include media-down(md) {
			position: static;
			flex-direction: row;
			flex-wrap: wrap;
			gap: $spacing-2;
		}
	}

	.faq-cat-tab {
		padding: $spacing-3 $spacing-4;
		font-size: $font-size-base;
		font-weight: $font-weight-normal;
		color: var(--color-text-secondary);
		background: transparent;
		border: none;
		border-left: 3px solid transparent;
		border-radius: 0;
		cursor: pointer;
		text-align: left;
		transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
		line-height: 1.5;

		@include media-down(md) {
			font-size: $font-size-sm;
			padding: $spacing-2 $spacing-3;
			border-left: none;
			border-bottom: 2px solid transparent;
		}

		&:hover {
			color: var(--color-text);
		}

		&.active {
			color: var(--color-text);
			font-weight: $font-weight-semibold;
			border-left-color: var(--color-primary);
			background: var(--color-bg-surface);

			@include media-down(md) {
				border-left-color: transparent;
				border-bottom-color: var(--color-primary);
			}
		}
	}

	// ─── Content ───
	.faq-content-area {
		min-width: 0;
	}

	.faq-category-content {
		display: none;
		&.active { display: block; }
	}

	// ─── FAQ item — card-style with white background ───
	.faq-item {
		background: var(--color-bg);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
		margin-bottom: $spacing-2;

		&--hidden {
			display: none;
		}

		&.expanded {
			border-color: var(--color-primary);

			.faq-chevron {
				transform: rotate(180deg);
			}
		}
	}

	// ─── Question row ───
	.faq-question {
		width: 100%;
		display: flex;
		align-items: center;
		gap: $spacing-4;
		padding: $spacing-4 $spacing-5;
		border: none;
		background: none;
		cursor: pointer;
		text-align: left;
		color: var(--color-text);

		&:hover .faq-question-text {
			color: var(--color-primary);
		}
	}

	.faq-question-text {
		// Element is h3 for SEO — reset browser defaults to keep original row styling.
		flex: 1;
		margin: 0;
		font-size: $font-size-base;
		font-weight: $font-weight-medium;
		line-height: 1.5;
		color: var(--color-text);
		transition: color 0.15s ease;
	}

	// Drawn as CSS masks so ~500 FAQ rows share one icon definition instead of
	// one inline SVG each; `currentColor` keeps the existing theming. One
	// variable per icon — mask and -webkit-mask must stay identical.
	$faq-chevron-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='none' stroke='black' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m6 9l6 6l6-6'/></svg>");
	$faq-link-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='none' stroke='black' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m9 15l6-6m-4-3l.463-.536a5 5 0 0 1 7.071 7.072L18 13m-5 5l-.397.534a5.07 5.07 0 0 1-7.127 0a4.97 4.97 0 0 1 0-7.071L6 11'/></svg>");

	.faq-chevron {
		display: block;
		width: 18px;
		height: 18px;
		color: var(--color-text-secondary);
		background-color: currentColor;
		mask: $faq-chevron-icon no-repeat center / contain;
		-webkit-mask: $faq-chevron-icon no-repeat center / contain;
		flex-shrink: 0;
		transition: transform 0.25s ease;
	}

	// ─── Copy link (inline right after question text) ───
	.faq-copy-link {
		position: relative;
		display: inline-flex;
		vertical-align: baseline;
		margin-left: 6px;
		cursor: pointer;
		opacity: 0;
		color: var(--color-primary);
		transition:
			opacity 0.15s ease,
			color 0.15s ease;

		// The link glyph, masked from a shared definition (same reason as
		// .faq-chevron). The tooltip already occupies ::after.
		&::before {
			content: '';
			display: block;
			width: 14px;
			height: 14px;
			background-color: currentColor;
			mask: $faq-link-icon no-repeat center / contain;
			-webkit-mask: $faq-link-icon no-repeat center / contain;
		}

		.faq-question:hover & {
			opacity: 0.6;
		}

		&:hover {
			opacity: 1 !important;
		}

		// Tooltip
		&::after {
			content: 'Copy link';
			position: absolute;
			bottom: calc(100% + 6px);
			left: 50%;
			transform: translateX(-50%);
			padding: 4px 8px;
			background: var(--color-text);
			color: var(--color-bg-surface);
			font-size: 11px;
			font-weight: $font-weight-medium;
			white-space: nowrap;
			border-radius: $radius-sm;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.15s ease;
		}

		&:hover::after {
			opacity: 1;
		}

		// Copied state
		&.copied {
			opacity: 1;
			color: var(--color-success);

			&::after {
				content: 'Copied!';
				opacity: 1;
				background: var(--color-success);
			}
		}
	}

	// Forced-colors palettes override background-color in ways that can blank
	// mask-drawn glyphs (inline SVGs used to get forced stroke colors); pin
	// the icons to the system text color so they stay visible.
	@media (forced-colors: active) {
		.faq-chevron,
		.faq-copy-link::before {
			background-color: CanvasText;
		}
	}

	// ─── Answer (smooth expand via grid trick) ───
	.faq-answer {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.25s ease;

		.faq-item.expanded & {
			grid-template-rows: 1fr;
		}
	}

	// This div clips everything — padding/border must be INSIDE it
	.faq-answer-overflow {
		overflow: hidden;
	}

	.faq-answer-content {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-text);

		& *:not(a):not(strong):not(b) {
			font-size: inherit !important;
			line-height: inherit !important;
			color: inherit !important;
		}
		border-top: 1px solid var(--sl-color-gray-5);
		margin: 0 $spacing-5;
		padding: $spacing-4 0 $spacing-5;

		a {
			color: var(--color-primary);
			text-decoration: none;
			&:hover { text-decoration: underline; }
		}

		ul {
			list-style: disc !important;
			list-style-position: outside;
			padding-left: $spacing-6;
			margin: $spacing-2 0;
		}

		ol {
			list-style: decimal !important;
			list-style-position: outside;
			padding-left: $spacing-6;
			margin: $spacing-2 0;
		}

		li {
			margin-bottom: $spacing-1;
			display: list-item;
			list-style: inherit !important;
		}

		strong, b {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
		}

		em, i {
			font-style: italic;
		}

		p {
			margin: $spacing-2 0;
			&:first-child { margin-top: 0; }
		}
	}

	// ─── Load more ───
	.faq-load-more {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: $spacing-3;
		margin: $spacing-2 0;
		border: 1px dashed var(--sl-color-gray-5);
		border-radius: $radius-lg;
		background: none;
		cursor: pointer;
		color: var(--color-primary);
		font-size: $font-size-sm;
		font-weight: $font-weight-semibold;
		transition: background-color 0.15s ease, border-color 0.15s ease;

		&:hover {
			background: var(--color-bg-light);
			border-color: var(--color-primary);
		}

		&.faq-load-more--used {
			display: none;
		}
	}
</style>
