---
import { Icon } from 'astro-icon/components';
import type { ComparisonRow } from '@data/pricing/types.ts';

interface Props {
	title?: string;
	subtitle?: string;
	headers: string[];
	rows: ComparisonRow[];
}

const {
	title = 'Additional features',
	subtitle = 'Extra details and upgrade options for all subscription plans.',
	headers,
	rows,
} = Astro.props;
---

<div class="comparison-section">
	<h3 class="comparison-title">{title}</h3>
	{subtitle && <p class="comparison-subtitle">{subtitle}</p>}

	<div class="comparison-table-wrap">
		<table class="comparison-table">
			{/* Authoritative column widths for `table-layout: fixed`.
				 Setting widths via <col> is honored by every browser and
				 survives any specificity drift on the per-class width rules
				 below — those become a redundant fallback. */}
			<colgroup>
				<col style="width: 30%" />
				{headers.map(() => (
					<col style="width: 17.5%" />
				))}
			</colgroup>
			<thead>
				<tr>
					<th class="comparison-feature-col"></th>
					{headers.map((h) => (
						<th class="comparison-plan-col">{h}</th>
					))}
				</tr>
			</thead>
			<tbody>
				{rows.map((row) => {
					// For rows with an (i) tooltip, bond the icon to the last
					// word of the label via a nowrap span so the icon never
					// orphans onto its own line at narrow viewports. Rows
					// without a tooltip render the label as-is so long ones
					// like "Dedicated customer success engineer" wrap freely.
					const hasTip = !!(row.faqId || row.faqTooltip);
					const lastSpace = hasTip ? row.feature.lastIndexOf(' ') : -1;
					const head = lastSpace !== -1 ? row.feature.slice(0, lastSpace + 1) : '';
					const tail = lastSpace !== -1 ? row.feature.slice(lastSpace + 1) : row.feature;
					return (
					<tr>
						<td class="comparison-feature-name">
							{hasTip ? (
								<>
									{head}<span class="comparison-feature-tail">{tail}<span class="comparison-tooltip-trigger" data-faq-id={row.faqId}>
										<Icon name="tabler:info-circle" class="comparison-tooltip-icon" />
										{row.faqTooltip && (
											<span class="comparison-tooltip">
												<span class="comparison-tooltip-arrow"></span>
												<span class="comparison-tooltip-body">
													<span set:html={row.faqTooltip} />
													{row.autoTooltip && row.faqId && <span class="comparison-tooltip-readmore"> read more</span>}
												</span>
											</span>
										)}
									</span></span>
								</>
							) : (
								row.feature
							)}
						</td>
						{row.values.map((val) => (
							<td class="comparison-cell">
								{val === true ? (
									<Icon name="tabler:check" class="comparison-check" />
								) : val === false ? (
									<span></span>
								) : val.toLowerCase() === 'contact us' ? (
									<a href="/contact-us/" class="comparison-link">Contact us</a>
								) : (
									<span class="comparison-text">{val}</span>
								)}
							</td>
						))}
					</tr>
					);
				})}
			</tbody>
		</table>
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.comparison-section {
		margin-bottom: $spacing-16;
	}

	.comparison-title {
		@include subsection-title;
		color: var(--color-text);
		margin: 0 0 $spacing-2;
	}

	.comparison-subtitle {
		@include text-m;
		color: var(--color-text-secondary);
		margin: 0 0 $spacing-6;
	}

	.comparison-table-wrap {
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.comparison-table {
		width: 100%;
		border-collapse: collapse;
		table-layout: fixed;
		min-width: 600px;

		@include media-down(md) {
			min-width: 500px;
		}
	}

	.comparison-table thead th {
		padding: $spacing-4 $spacing-3;
		font-size: $font-size-lg;
		font-weight: $font-weight-bold;
		color: var(--color-text);
		text-align: center;
		border-bottom: 1px solid var(--sl-color-gray-5);

		@include media-down(md) {
			font-size: $font-size-base;
			padding: $spacing-3 $spacing-2;
		}
	}

	.comparison-feature-col {
		text-align: left !important;
		width: 30%;
	}

	.comparison-plan-col {
		width: 17.5%;
	}

	.comparison-table tbody tr {
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.comparison-feature-name {
		padding: $spacing-3 $spacing-3 $spacing-3 0;
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		white-space: nowrap;

		@include media-down(md) {
			font-size: $font-size-xs;
			white-space: normal;
		}
	}

	// Bonds the last word of the feature label to the (i) tooltip icon so
	// they wrap together — otherwise the icon orphans onto its own line when
	// the label wraps to two lines on narrow viewports.
	.comparison-feature-tail {
		white-space: nowrap;
	}

	.comparison-cell {
		padding: $spacing-3;
		text-align: center;
		vertical-align: middle;

		@include media-down(md) {
			padding: $spacing-2;
		}
	}

	.comparison-check {
		width: 16px;
		height: 16px;
		color: var(--color-primary);
	}

	.comparison-text {
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text);
	}

	.comparison-link {
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-primary);
		text-decoration: none;

		&:hover {
			text-decoration: underline;
		}
	}

	// ─── Tooltip trigger + popup (same pattern as plan feature tooltips) ───
	.comparison-tooltip-trigger {
		position: relative;
		display: inline;
		cursor: pointer;
		margin-left: 0;
	}

	.comparison-tooltip-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text);
		opacity: 0.8;
		vertical-align: text-top;
		margin-top: -1px;
		margin-left: -2px;
		transition: color 0.2s ease, opacity 0.2s ease;
	}

	.comparison-tooltip-trigger:hover .comparison-tooltip-icon {
		color: var(--color-primary);
		opacity: 1;
	}

	.comparison-tooltip {
		position: fixed;
		z-index: 99999;
		pointer-events: none;
		left: -9999px;
		top: 0;
		display: flex;
		align-items: center;

		opacity: 0;
		visibility: hidden;
		transition: opacity 0.15s ease, visibility 0.15s ease;
		transition-delay: 0ms;

		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: -12px;
			width: 16px;
			height: 100%;
		}
	}

	.comparison-tooltip.pricing-tooltip--visible {
		opacity: 1;
		visibility: visible;
		pointer-events: none;
		&.pricing-tooltip--interactive { pointer-events: auto; }
	}

	.comparison-tooltip-arrow {
		flex-shrink: 0;
		width: 0;
		height: 0;
		border: 6px solid transparent;
		border-right-color: var(--sl-color-gray-5);
		position: relative;

		&::after {
			content: '';
			position: absolute;
			top: -6px;
			left: -4px;
			width: 0;
			height: 0;
			border: 6px solid transparent;
			border-right-color: var(--color-bg-surface);
		}
	}

	.comparison-tooltip-readmore {
		color: var(--color-primary);
		cursor: pointer;

		&:hover {
			text-decoration: underline;
		}
	}

	.comparison-tooltip-body {
		display: block;
		padding: $spacing-3;
		background: var(--color-bg-surface);
		color: var(--color-text);
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: 1.5;
		text-align: left;
		white-space: normal;
		width: 280px;
		border-radius: $radius-lg;
		border: 1px solid var(--sl-color-gray-5);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>
