<script is:inline>
	(function () {
		try {
			const url = new URL(window.location.href);
			const params = {};
			url.searchParams.forEach(function (value, key) {
				if (key.startsWith('utm_')) {
					params[key] = value;
				}
			});
			if (Object.keys(params).length > 0) {
				localStorage.setItem('utm', JSON.stringify(params));
			}
			const fpr = url.searchParams.get('fpr');
			if (fpr) {
				localStorage.setItem('fpr', fpr);
			}
		} catch { /* ignore */ }

		function patchLinks() {
			let searchParams = [];

			const utms = localStorage.getItem('utm');
			if (utms) {
				let utm = {};
				try {
					utm = JSON.parse(utms);
				} catch { /* ignore */ }
				searchParams = Object.keys(utm).map(function (key) {
					return key + '=' + encodeURIComponent(utm[key]);
				});
			}

			const fpr = localStorage.getItem('fpr');
			if (fpr) {
				searchParams.push('fpr=' + encodeURIComponent(fpr));
			}

			const search = searchParams.join('&');
			if (!search) return;

			const allowedDomains = [
				'https://thingsboard.cloud',
				'https://eu.thingsboard.cloud',
				'https://license.thingsboard.io',
			];

			Array.from(document.links).forEach(function (link) {
				const href = link.getAttribute('href');
				if (href && allowedDomains.some(function (d) { return href.startsWith(d); })) {
					const separator = href.includes('?') ? '&' : '?';
					link.setAttribute('href', href + separator + search);
				}
			});
		}

		// Rewriting every outbound link is only needed by the time the user
		// clicks one, so run it at idle instead of blocking the load path.
		const idle = window.requestIdleCallback || ((cb) => setTimeout(cb, 200));
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', () => idle(patchLinks));
		} else {
			idle(patchLinks);
		}
	})();
</script>
