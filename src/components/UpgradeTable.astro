---
import type { Products } from '~/models/site.models';
import { UPGRADE_VERSIONS, getFamilySlug } from '~/models/upgrade-instructions';
import {
	RELEASE_FAMILIES,
	familySlug as getReleasesFamilySlug,
	patchSlug,
} from '~/models/releases-table';

/** 'Mar 18 2022' → 'March 18, 2022' (format expected by patchSlug). */
function toLongDate(short: string): string {
	const d = new Date(short);
	if (isNaN(d.getTime())) return short;
	return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

interface Props {
	product: Products;
}

const { product } = Astro.props;

const isPE = product === 'PE';
const docsPrefix = isPE ? 'pe/' : '';
const platformBase = `/docs/${docsPrefix}installation/upgrade-instructions`;
const releasesBase = `/docs/${docsPrefix}releases/releases-table`;

// Map raw upgrade-table version (e.g. "4.3.0.1") → release-notes heading anchor
// (e.g. "v4301-feb-3-2026"). PatchEntry.version is "v"-prefixed; strip it.
const patchAnchorByVersion = new Map<string, string>();
for (const family of RELEASE_FAMILIES) {
	for (const patch of family.patches) {
		patchAnchorByVersion.set(patch.version.replace(/^v/, ''), patchSlug(patch.version, patch.date));
	}
}

// Platform icons served straight from `public/icons/installation/`. The table
// renders ~78 versions × 5 platforms = ~390 cells per page; routing icons via
// Astro's asset pipeline let Vite inline anything under its 4 KB threshold as
// a per-cell data URI, which still added ~300 KB of duplicated markup on the
// upgrade pages. Hard-coded `public/` URLs guarantee a single shared HTTP
// request per icon (browser-cached across all upgrade pages), independent of
// version count. These five icons are stable brand assets — keeping them out
// of the hashed asset pipeline is an acceptable tradeoff for the size win.
const platforms = [
	{ key: 'docker', label: 'Docker upgrade instructions', icon: '/icons/installation/docker.svg' },
	{ key: 'docker-compose', label: 'Docker Compose upgrade instructions', icon: '/icons/installation/docker-compose.svg' },
	{ key: 'windows', label: 'Windows upgrade instructions', icon: '/icons/installation/windows.svg' },
	{ key: 'ubuntu', label: 'Ubuntu upgrade instructions', icon: '/icons/installation/ubuntu.svg' },
	{ key: 'centos', label: 'CentOS/RHEL upgrade instructions', icon: '/icons/installation/cent-os.svg' },
];

function formatDate(dateStr: string): string {
	try {
		const d = new Date(dateStr);
		if (isNaN(d.getTime())) return dateStr;
		return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
	} catch {
		return dateStr;
	}
}
---

<script is:inline>
	if (new URLSearchParams(location.search).has('version')) {
		document.documentElement.classList.add('upgrade-filtering');
	}
</script>

<div class="upgrade-filter-banner" hidden>
	Showing upgrade instructions for version <strong class="upgrade-filter-version"></strong>.
	<a class="upgrade-filter-clear" href="">Show all versions</a>
</div>

<div class="upgrade-table-wrapper not-content">
	<table class="upgrade-table">
		<thead>
			<tr>
				<th>Version</th>
				<th>Release Date</th>
				<th>Upgradable From</th>
				<th>
					<a
						class="lts-header-link"
						href={`/docs/${docsPrefix}releases/release-policy/#lifecycle-and-support`}
					>
						LTS
					</a>
				</th>
				<th>Release Notes</th>
				<th>Upgrade Instructions</th>
			</tr>
		</thead>
		<tbody>
			{UPGRADE_VERSIONS.filter((v) => !v.vulnerable).map((v) => {
				const releaseDate = isPE && v.releaseDatePe ? v.releaseDatePe : v.releaseDate;
				const versionLabel = isPE ? `v${v.displayVersion} PE` : `v${v.displayVersion}`;
				const upgradableFromLabel = isPE
					? `v${v.upgradableFrom} PE`
					: `v${v.upgradableFrom}`;
				const releaseNotesBase = `${releasesBase}/${getReleasesFamilySlug(v.family)}/`;
				// PE release notes use PE-specific dates when set; derive a matching anchor instead of the CE default.
				const releaseNotesAnchor =
					isPE && v.releaseDatePe
						? patchSlug(`v${v.version}`, toLongDate(v.releaseDatePe))
						: patchAnchorByVersion.get(v.version);
				const releaseNotesHref = releaseNotesAnchor
					? `${releaseNotesBase}#${releaseNotesAnchor}`
					: releaseNotesBase;

				return (
					<tr data-anchor={v.anchor}>
						<td class="version-col">{versionLabel}</td>
						<td class="date-col">
							<time datetime={new Date(releaseDate).toISOString().split('T')[0]}>
								{formatDate(releaseDate)}
							</time>
						</td>
						<td class="from-col">{upgradableFromLabel}</td>
						<td class="lts-col">
							{v.lts ? (
								<span class="status-badge status-active-lts">Available</span>
							) : (
								<span class="status-badge status-standard">Not available</span>
							)}
						</td>
						<td class="notes-col">
							<a
								href={releaseNotesHref}
								class="notes-link"
								title={`Release notes for v${v.displayVersion}`}
							>
								<span>v{v.displayVersion}</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path stroke="none" d="M0 0h24v24H0z" fill="none" />
									<path d="M17 7l-10 10" />
									<path d="M8 7l9 0l0 9" />
								</svg>
							</a>
						</td>
						<td class="icons-col">
							{platforms.map((p) => (
								<a
									href={`${platformBase}/${p.key}/${getFamilySlug(v.family)}/#${v.anchor}`}
									title={p.label}
									class="platform-icon"
								>
									<img
										src={p.icon}
										alt={p.label}
										class="icon-svg"
										width="36"
										height="36"
										loading="lazy"
										decoding="async"
									/>
								</a>
							))}
						</td>
					</tr>
				);
			})}
		</tbody>
	</table>
</div>

<script>
	const filter = new URLSearchParams(window.location.search).get('version');
	if (filter) {
		const isWildcard = filter.endsWith('-x');
		// 'v4-3-x' → prefix 'v4-3-'  (strip the trailing 'x', keep the '-')
		const prefix = isWildcard ? filter.slice(0, -1) : filter;

		const rows = document.querySelectorAll<HTMLTableRowElement>(
			'.upgrade-table tbody tr[data-anchor]',
		);
		rows.forEach((row) => {
			const anchor = row.dataset.anchor ?? '';
			const matches = isWildcard ? anchor.startsWith(prefix) : anchor === filter;
			row.hidden = !matches;
		});

		document.documentElement.classList.remove('upgrade-filtering');

		const banner = document.querySelector<HTMLElement>('.upgrade-filter-banner');
		if (banner) {
			const versionEl = banner.querySelector('.upgrade-filter-version');
			if (versionEl) versionEl.textContent = filter;
			const clearLink = banner.querySelector<HTMLAnchorElement>('.upgrade-filter-clear');
			if (clearLink) clearLink.href = window.location.pathname;
			banner.hidden = false;
		}
	}
</script>

<style>
	:global(.sl-container:has(.upgrade-table-wrapper)) {
		max-width: 100%;
	}

	.upgrade-filter-banner[hidden] {
		display: none;
	}

	.upgrade-filter-banner {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.6rem 1rem;
		margin-block-end: 1rem;
		border-inline-start: 0.25rem solid var(--sl-color-blue);
		background: var(--sl-color-blue-low);
		border-radius: 0 4px 4px 0;
		font-size: 0.9rem;
	}

	.upgrade-filter-clear {
		margin-inline-start: auto;
		font-size: 0.85rem;
		white-space: nowrap;
	}

	.upgrade-table-wrapper {
		overflow-x: auto;
		margin-block: 1.5rem;
	}

	:global(.upgrade-filtering) .upgrade-table tbody tr {
		display: none;
	}

	.upgrade-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
		white-space: nowrap;
	}

	.upgrade-table th,
	.upgrade-table td {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		text-align: left;
		vertical-align: middle;
	}

	.upgrade-table th {
		background: var(--sl-color-gray-6);
		font-weight: 600;
	}

	.upgrade-table tbody tr:hover {
		background: var(--sl-color-gray-7);
	}

	.version-col {
		font-weight: 600;
	}

	.lts-header-link {
		color: var(--sl-color-text-accent);
		text-decoration: underline;
	}

	.status-badge {
		display: inline-block;
		padding: 0.2em 0.55em;
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.status-active-lts {
		background: color-mix(in srgb, var(--sl-color-green) 15%, transparent);
		color: var(--sl-color-green);
	}

	.status-standard {
		background: color-mix(in srgb, var(--sl-color-gray-3) 15%, transparent);
		color: var(--sl-color-gray-3);
	}

	.notes-col {
		white-space: nowrap;
	}

	.notes-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}

	.notes-link:hover {
		text-decoration: underline;
	}

	.icons-col {
		white-space: nowrap;
		width: 1px;
		transition: filter 0.15s;
		filter: grayscale(1) opacity(0.45);
	}

	.upgrade-table tbody tr:hover .icons-col {
		filter: none;
	}

	.platform-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		margin: 0 2px;
		border-radius: 4px;
		transition: background 0.15s;
		text-decoration: none;
	}

	.platform-icon:hover {
		background: var(--sl-color-gray-5);
	}

	.icon-svg {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
	}

	.icon-svg :global(svg) {
		width: 22px;
		height: 22px;
	}
</style>
