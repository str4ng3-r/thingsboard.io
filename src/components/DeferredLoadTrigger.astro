<script is:inline>
	(function () {
		const STORAGE_KEY = 'tb:user-engaged';
		const pending = new Map();

		let fired = false;
		try {
			fired = sessionStorage.getItem(STORAGE_KEY) !== null;
		} catch {
			/**/
		}

		const runCallback = (cb) => {
			try {
				cb();
			} catch (err) {
				console.error('deferred loader callback failed', err);
			}
		};

		const runOne = (cb) => {
			if (!pending.has(cb)) return;
			clearTimeout(pending.get(cb));
			pending.delete(cb);
			runCallback(cb);
		};

		// Default API: if the user already interacted earlier in the session,
		// run immediately; otherwise wait for interaction on this page or the
		// fallback timer.
		//
		// Idle-fallback schedule — the authoritative table for every caller;
		// keep the ordering when tuning any tier:
		//   2500 (default) — MailerLite demo-form embed (DemoRequestForm.astro)
		//   5000           — GTM + injected tags (GtmHead.astro)
		//   5500           — GitHub star-count fetch, after GTM (Landing/GitHubButton.astro)
		//  10000           — YourGPT chat widget (YourGptWidget.astro)
		window.__deferOnInteraction = function (cb, fallbackMs) {
			if (fired) return runCallback(cb);
			const ms = typeof fallbackMs === 'number' ? fallbackMs : 2500;
			pending.set(cb, setTimeout(() => runOne(cb), ms));
		};

		const events = ['pointerdown', 'keydown', 'scroll', 'touchstart'];
		const fire = () => {
			if (fired) return;
			fired = true;
			try {
				sessionStorage.setItem(STORAGE_KEY, String(Date.now()));
			} catch {
				/**/
			}
			events.forEach((e) => window.removeEventListener(e, fire));
			for (const cb of [...pending.keys()]) runOne(cb);
		};

		if (!fired) {
			events.forEach((e) => window.addEventListener(e, fire, { once: true, passive: true }));
		}
	})();
</script>
