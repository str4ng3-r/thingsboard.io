<!--
	Shared trigger for deferring third-party scripts (GTM, YourGPT chatbot, etc.)
	until the user shows intent — first interaction OR a per-callback fallback
	timer (caller passes fallbackMs; default 2.5s, counted from registration).

	Consumers call `window.__deferOnInteraction(cb, fallbackMs?)`. The callback
	fires once on whichever happens first: a user interaction event, or its
	own fallback timeout. Callers registered after the interaction has already
	fired execute synchronously.

	Per-callback fallback lets heavy scripts wait longer than light ones:
	YourGPT passes 10000 to stay outside Lighthouse's trace window, GTM keeps
	the 2.5s default so bounce sessions still record.

	The trigger itself does NOT skip localhost so the defer behaviour can be
	measured in a local Lighthouse run. Whether to register a callback at all
	on localhost is the consumer's decision (e.g. GtmHead skips, YourGpt does
	not).
-->
<script is:inline>
	(function () {
		const pending = new Map();
		let fired = false;

		const runCallback = (cb) => {
			try {
				cb();
			} catch (err) {
				console.error('deferred loader callback failed', err);
			}
		};

		const runOne = (cb) => {
			if (!pending.has(cb)) return;
			clearTimeout(pending.get(cb));
			pending.delete(cb);
			runCallback(cb);
		};

		window.__deferOnInteraction = function (cb, fallbackMs) {
			if (fired) return runCallback(cb);
			const ms = typeof fallbackMs === 'number' ? fallbackMs : 2500;
			pending.set(cb, setTimeout(() => runOne(cb), ms));
		};

		const events = ['pointerdown', 'keydown', 'scroll', 'touchstart'];
		const fire = () => {
			if (fired) return;
			fired = true;
			events.forEach((e) => window.removeEventListener(e, fire));
			for (const cb of [...pending.keys()]) runOne(cb);
		};

		events.forEach((e) => window.addEventListener(e, fire, { once: true, passive: true }));

		// Two-step cleanup pattern: { once: true } removes only the listener that
		// actually fired; the explicit removeEventListener loop in fire() cleans
		// up the other 3 events that are still waiting. Don't drop either half.
	})();
</script>
