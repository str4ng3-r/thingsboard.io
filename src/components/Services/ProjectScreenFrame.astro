---
export interface Props {
	/** Image source URL. Not needed when using the default slot. */
	src?: string;
	alt?: string;
	width?: number;
	height?: number;
	id?: string;
	/** Content border-radius. Default `5px`. */
	borderRadius?: string;
	/** Loading strategy for the default image. Default `lazy`. */
	loading?: 'lazy' | 'eager';
	/** Accent frame color (front layer). Default `#3e9af8`. */
	accentColor?: string;
	/** Muted frame color (middle layer). Default `#d1e9ff`. */
	mutedColor?: string;
	/** Fill background color (back layer). Default `#f4f8fe`. */
	fillColor?: string;
	/** Content opacity transition duration. Default `0.3s`. */
	transitionDuration?: string;
	/** CSS inset for the front accent border layer. Default `8% -8% -8% 8%`. */
	frontInset?: string;
	/** CSS inset for the middle muted border layer. Default `-6% 6% 6% -6%`. */
	middleInset?: string;
	/** CSS inset for the back fill layer. Default `-12% -5% 12% 5%`. */
	backInset?: string;
	class?: string;
}

const {
	src,
	alt,
	width,
	height,
	id,
	borderRadius = '5px',
	loading = 'lazy',
	accentColor = '#3e9af8',
	mutedColor = '#d1e9ff',
	fillColor = '#f4f8fe',
	transitionDuration = '0.3s',
	frontInset = '8% -8% -8% 8%',
	middleInset = '-6% 6% 6% -6%',
	backInset = '-12% -5% 12% 5%',
	class: className,
} = Astro.props;

const hasSlot = Astro.slots.has('default');
---

<div
	class:list={['project-screen-frame', className]}
	style={`--psf-accent: ${accentColor}; --psf-muted: ${mutedColor}; --psf-fill: ${fillColor}; --psf-img-radius: ${borderRadius}; --psf-transition: ${transitionDuration}; --psf-front-inset: ${frontInset}; --psf-middle-inset: ${middleInset}; --psf-back-inset: ${backInset};`}
>
	<div class="psf-inner">
		{
			hasSlot ? (
				<slot />
			) : (
				<img {...(id ? { id } : {})} src={src} alt={alt!} width={width!} height={height!} loading={loading} />
			)
		}
	</div>
</div>

<style lang="scss">
	.project-screen-frame {
		position: relative;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.psf-inner {
		position: relative;
		width: 100%;
		isolation: isolate;

		img,
		:global(video) {
			display: block;
			width: 100%;
			height: auto;
			border-radius: var(--psf-img-radius);
			transition: opacity var(--psf-transition) ease;
		}

		// Layer 1 (front): accent border, offset down-right
		&::before {
			content: '';
			position: absolute;
			inset: var(--psf-front-inset);
			z-index: -1;
			border-radius: 24px;
			border: 1.5px solid var(--psf-accent);
		}

		// Layer 2 (middle): muted border, offset up-left
		&::after {
			content: '';
			position: absolute;
			inset: var(--psf-middle-inset);
			z-index: -2;
			border-radius: 24px;
			border: 1.5px solid var(--psf-muted);
		}
	}

	// Layer 3 (back): filled bg
	.project-screen-frame::before {
		content: '';
		position: absolute;
		inset: var(--psf-back-inset);
		z-index: 0;
		border-radius: 24px;
		background: var(--psf-fill);
	}

	@media (max-width: 959px) {
		.psf-inner {
			&::before {
				inset: var(--psf-front-inset-sm, 2% -1.5% -2% 1.5%);
			}

			&::after {
				inset: var(--psf-middle-inset-sm, -3% 2% 3% -2%);
			}
		}

		.project-screen-frame::before {
			inset: var(--psf-back-inset-sm, -3.5% -1.5% 3.5% 1.5%);
		}
	}
</style>
