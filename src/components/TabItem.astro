---
/**
 * Drop-in replacement for Starlight's <TabItem> that adds an `id` prop
 * used for URL-based tab sync (urlParam feature of ~/components/Tabs.astro).
 *
 * Usage:
 *   import TabItem from '~/components/TabItem.astro';
 *
 *   <TabItem label="Cloud" icon="tabler:cloud" id="cloud">...</TabItem>
 */
interface Props {
	label: string;
	icon?: string;
	/** URL-friendly identifier used with <Tabs urlParam="...">. */
	id?: string;
}

const { label, icon, id } = Astro.props;
---

<starlight-tab-item data-label={label} data-icon={icon || ''} data-tab-id={id || ''}>
	<slot />
</starlight-tab-item>