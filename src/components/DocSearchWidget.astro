<div class="doc-search-widget">
	<div class="gcse-search"></div>
</div>

<script>
	// Ensure CSE script is loaded (may already be loaded by SearchButton)
	if (!document.querySelector('script[src*="cse.google.com"]')) {
		const script = document.createElement('script');
		script.async = true;
		script.src = 'https://cse.google.com/cse.js?cx=006967103846171422263:o5lnt35mvwq';
		document.head.appendChild(script);
	}

	// Execute search from URL param once CSE renders the input
	const widget = document.querySelector<HTMLElement>('.doc-search-widget');
	const q = new URLSearchParams(window.location.search).get('q');
	if (q) {
		const tryExecute = (attempts = 0) => {
			const input = widget?.querySelector<HTMLInputElement>('input.gsc-input');
			if (input) {
				input.value = q;
				input.dispatchEvent(new Event('input', { bubbles: true }));
				const btn = widget?.querySelector<HTMLElement>('button.gsc-search-button');
				if (btn) btn.click();
				return;
			}
			if (attempts < 100) setTimeout(() => tryExecute(attempts + 1), 100);
		};
		tryExecute();
	}
</script>

<style is:global>
	.doc-search-widget {
		margin-top: 1rem;
		/* Cap the whole widget so the input and result rows share the same
		   right edge. 45rem matches Google CSE's natural result-row width,
		   so input (forced to 100%) and results (also 100%) align cleanly.
		   Wider caps caused the input to extend past the results. */
		max-width: 45rem;
		/* Do NOT set overflow-x:hidden here — per CSS spec, browsers
		   compute overflow-y as `auto` when overflow-x is anything other
		   than `visible`, which produces a phantom inner scrollbar.
		   Prevent horizontal overflow by sizing children instead. */
	}
	/* Top-level CSE container — make sure the outermost Google div doesn't
	   shrink to content (it can default to display: inline-block). */
	.doc-search-widget .gcse-search {
		display: block !important;
		width: 100% !important;
		max-width: 100% !important;
	}
	/* Force the CSE results wrappers AND each individual result row to
	   fill the widget column so they match the input width (otherwise
	   Google CSE shrinks them to content size). */
	.doc-search-widget .gsc-results.gsc-webResult,
	.doc-search-widget .gsc-results,
	.doc-search-widget .gsc-resultsRoot,
	.doc-search-widget .gsc-resultsbox-visible,
	.doc-search-widget .gsc-results-wrapper-overlay,
	.doc-search-widget .gsc-results-wrapper-nooverlay,
	.doc-search-widget .gsc-result,
	.doc-search-widget .gsc-webResult,
	.doc-search-widget .gsc-webResult.gsc-result {
		display: block !important;
		width: 100% !important;
		max-width: 100% !important;
		box-sizing: border-box !important;
	}
	.doc-search-widget :is(th, td) {
		border: none !important;
	}
	/* Force every Google-CSE wrapper layer to full width so the input
	   stretches to fill the content column instead of rendering as a
	   ~270px box. CSE's structure is:
	     .gsc-control-cse > form.gsc-search-box > table.gsc-search-box
	       > td.gsc-input > .gsc-input-box > table > td.gsib_a > input
	   Each layer has its own auto-sizing, so we have to override them all. */
	.doc-search-widget .gsc-control-cse,
	.doc-search-widget .gsc-control-wrapper-cse {
		width: 100% !important;
		max-width: 100% !important;
		padding: 0 !important;
		margin: 0 !important;
		box-sizing: border-box !important;
	}
	.doc-search-widget form.gsc-search-box,
	.doc-search-widget table.gsc-search-box {
		display: block !important;
		width: 100% !important;
		max-width: 100% !important;
		padding: 0 !important;
		margin: 0 !important;
		box-sizing: border-box !important;
	}
	.doc-search-widget table.gsc-search-box > tbody,
	.doc-search-widget table.gsc-search-box > tbody > tr {
		display: flex !important;
		width: 100% !important;
		gap: 0.5rem !important;
		align-items: stretch !important;
	}
	.doc-search-widget td.gsc-input {
		display: block !important;
		flex: 1 1 auto !important;
		width: auto !important;
		padding: 0 !important;
	}
	.doc-search-widget td.gsc-search-button,
	.doc-search-widget td.gsc-clear-button {
		flex: 0 0 auto !important;
	}
	.doc-search-widget .gsc-input-box {
		width: 100% !important;
		max-width: none !important;
		box-sizing: border-box !important;
	}
	.doc-search-widget .gsc-input-box > table,
	.doc-search-widget td.gsib_a {
		width: 100% !important;
	}
	.doc-search-widget input.gsc-input {
		min-width: 0 !important;
		width: 100% !important;
		max-width: none !important;
		box-sizing: border-box !important;
		font-size: 1rem !important;
	}
	.doc-search-widget .gsc-search-button button {
		padding: 0 1.25rem !important;
		font-size: 1rem !important;
	}

	/* Align "About N results" text flush with the input + result list */
	.doc-search-widget .gsc-result-info-container,
	.doc-search-widget .gsc-result-info-container td,
	.doc-search-widget .gsc-result-info {
		padding-left: 0 !important;
		margin-left: 0 !important;
		text-align: left !important;
	}

	/* "Search '<query>' on Google" footer — make icon + text render on one
	   line. By default Google CSE puts the magnifier SVG on its own block
	   above the link text, which looks broken. */
	.doc-search-widget .gcsc-find-more-on-google-root {
		text-align: center !important;
	}
	.doc-search-widget .gcsc-find-more-on-google {
		display: inline-flex !important;
		align-items: center !important;
		gap: 0.4rem !important;
	}
	.doc-search-widget .gcsc-find-more-on-google-magnifier,
	.doc-search-widget .gcsc-find-more-on-google svg {
		display: inline-block !important;
		width: 14px !important;
		height: 14px !important;
		vertical-align: middle !important;
		flex: 0 0 auto !important;
	}
	.doc-search-widget .gcsc-find-more-on-google-query {
		display: inline !important;
	}

	/* Tighter result spacing. Reset all borders first so Google CSE's
	   default rectangle outline doesn't show, then add only the bottom
	   hairline as a separator. */
	.doc-search-widget .gsc-webResult.gsc-result,
	.doc-search-widget .gsc-results .gsc-result {
		padding: 0.5rem 0 !important;
		margin-bottom: 0 !important;
		border: none !important;
		border-bottom: 1px solid var(--sl-color-hairline-light) !important;
	}
	.doc-search-widget .gsc-webResult-divider {
		display: none !important;
	}
	/* Tighten vertical rhythm inside each result (title → URL → snippet).
	   Reset margin/padding on ALL descendants of the snippet cell, then
	   re-introduce a tiny gap between siblings so they don't stick. */
	.doc-search-widget .gsc-table-cell-snippet-close,
	.doc-search-widget .gsc-table-cell-snippet-close * {
		margin: 0 !important;
		padding: 0 !important;
	}
	.doc-search-widget .gsc-table-cell-snippet-close > * + * {
		margin-top: 2px !important;
	}
	/* Slightly larger breathing space before the snippet body */
	.doc-search-widget .gsc-table-cell-snippet-close .gs-snippet,
	.doc-search-widget .gsc-table-cell-snippet-close .gsc-text-result-container {
		margin-top: 4px !important;
	}

	/* Convert each result row from <table> to a flex row so the text and
	   thumbnail get clean, non-overlapping columns. With table-layout: auto
	   the thumbnail <td> shrinks to fit and the snippet cell expands to
	   100%, causing the snippet text to overlap the image. Flex avoids that. */
	.doc-search-widget table.gsc-table-result {
		display: block !important;
		width: 100% !important;
	}
	.doc-search-widget table.gsc-table-result tbody {
		display: block !important;
		width: 100% !important;
	}
	.doc-search-widget table.gsc-table-result tr {
		display: flex !important;
		width: 100% !important;
		gap: 1rem !important;
		align-items: flex-start !important;
	}
	.doc-search-widget td.gsc-table-cell-snippet-close {
		display: block !important;
		flex: 1 1 0 !important;
		min-width: 0 !important;
		padding: 0 !important;
	}
	.doc-search-widget td.gsc-table-cell-thumbnail.gsc-thumbnail {
		display: block !important;
		flex: 0 0 160px !important;
		width: 160px !important;
		padding: 0 !important;
	}

	/* Rectangular thumbnails (16:9, matches OG image aspect) */
	.doc-search-widget .gs-image-box .gs-image,
	.doc-search-widget img.gs-image {
		width: 160px !important;
		height: 90px !important;
		max-width: 160px !important;
		max-height: 90px !important;
		object-fit: cover !important;
		border-radius: 4px !important;
	}

	/* Dark theme */
	[data-theme='dark'] .doc-search-widget .gsc-control-cse {
		background: transparent !important;
		border: none !important;
	}
	/* Drop the card-like grey background from each result in dark theme —
	   keep only the bottom-divider hairline so results look the same as
	   in light theme. */
	[data-theme='dark'] .doc-search-widget .gsc-webResult.gsc-result {
		background: transparent !important;
		color: var(--sl-color-text) !important;
		border-bottom-color: var(--sl-color-hairline-light) !important;
	}

	/* Theme the input itself for dark mode — Google CSE ships it with a
	   white background that looks jarring against the dark page. */
	[data-theme='dark'] .doc-search-widget .gsc-input-box,
	[data-theme='dark'] .doc-search-widget .gsc-input-box-focus,
	[data-theme='dark'] .doc-search-widget .gsc-input-box-hover {
		background: var(--sl-color-bg) !important;
		border-color: var(--sl-color-hairline) !important;
	}
	[data-theme='dark'] .doc-search-widget input.gsc-input,
	[data-theme='dark'] .doc-search-widget table.gsc-input,
	[data-theme='dark'] .doc-search-widget .gsib_a {
		background: var(--sl-color-bg) !important;
		color: var(--sl-color-text) !important;
	}
	/* Google injects an inline-styled background image on the input —
	   override the !important inline rule by re-stating with !important. */
	[data-theme='dark'] .doc-search-widget input.gsc-input {
		background-image: none !important;
	}
	/* Clear-button (X) icon should be visible on dark bg too */
	[data-theme='dark'] .doc-search-widget .gsst_a .gscb_a {
		color: var(--sl-color-text) !important;
	}
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title,
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title:link,
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title:visited {
		color: var(--sl-color-text-accent) !important;
	}
	/* The query-match <b> tags inside titles should inherit, not use
	   Google CSE's default visited/link colors. */
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title b,
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title:link b,
	[data-theme='dark'] .doc-search-widget .gsc-result a.gs-title:visited b {
		color: inherit !important;
	}
	/* Also apply <b> inheritance in light theme so visited titles stay
	   the accent color rather than showing Google's default purple. */
	.doc-search-widget .gsc-result a.gs-title,
	.doc-search-widget .gsc-result a.gs-title:link,
	.doc-search-widget .gsc-result a.gs-title:visited {
		color: var(--sl-color-text-accent) !important;
	}
	.doc-search-widget .gsc-result a.gs-title b,
	.doc-search-widget .gsc-result a.gs-title:link b,
	.doc-search-widget .gsc-result a.gs-title:visited b {
		color: inherit !important;
	}
	[data-theme='dark'] .doc-search-widget .gsc-result .gs-snippet {
		color: var(--sl-color-gray-2) !important;
	}
	[data-theme='dark'] .doc-search-widget .gs-visibleUrl {
		color: var(--sl-color-gray-3) !important;
	}
	[data-theme='dark'] .doc-search-widget .gsc-results .gsc-cursor-box .gsc-cursor-page {
		background: var(--sl-color-gray-6) !important;
		color: var(--sl-color-text) !important;
	}
	[data-theme='dark'] .doc-search-widget .gsc-results .gsc-cursor-box .gsc-cursor-current-page {
		background: var(--sl-color-text-accent) !important;
		color: var(--sl-color-white) !important;
	}
</style>