<!-- Google Tag Manager -->
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	window.gtag = function (...args) {
		window.dataLayer.push(args);
	};

	if (location.hostname !== 'localhost') {
		const loadGtm = () => {
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
				const f = d.getElementsByTagName(s)[0];
				const j = d.createElement(s);
				const dl = l !== 'dataLayer' ? '&l=' + l : '';
				j.async = true;
				j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, 'script', 'dataLayer', 'GTM-TGBNQXN');
		};

		if (new URL(window.location.href).searchParams.has('gtm_debug')) {
			loadGtm();
		} else {
			// 5s idle fallback (vs the 2.5s default) so tag-manager JS lands
			// after the LCP paint window for visitors who never interact.
			// Full tier schedule: DeferredLoadTrigger.astro.
			(window.__deferOnInteraction || ((cb) => cb()))(loadGtm, 5000);
		}
	}
</script>
<!-- End Google Tag Manager -->
