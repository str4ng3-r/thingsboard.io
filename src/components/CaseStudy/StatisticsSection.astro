---
import type { StatisticItem } from '@data/case-studies/types.ts';

interface Props {
	items: StatisticItem[];
}

const { items } = Astro.props;
---

<section class="cs-statistics">
	{items.map((item) => (
		<div class="cs-stat-block">
			<p class="cs-stat-value">{item.prefix && <span class="cs-stat-prefix">{item.prefix}</span>}<span class="cs-stat-number" data-target={item.value} data-grouping="true">0</span>{item.decimal && (<><span class="cs-stat-decimal-dot">.</span><span class="cs-stat-number" data-target={item.decimal.value} data-grouping="false">0</span>{item.decimal.suffix && <span class="cs-stat-suffix">{item.decimal.suffix}</span>}</>)}{item.suffix && <span class="cs-stat-suffix">{item.suffix}</span>}</p>
			<p class="cs-stat-label">{item.label}</p>
		</div>
	))}
</section>

<script>
	function animateNumber(el: HTMLElement) {
		const target = parseInt(el.dataset.target || '0', 10);
		const useGrouping = el.dataset.grouping !== 'false';
		const duration = 2000;
		const start = performance.now();
		const formatter = useGrouping ? new Intl.NumberFormat('en-US') : undefined;

		function update(now: number) {
			const elapsed = now - start;
			const progress = Math.min(elapsed / duration, 1);
			const eased = 1 - Math.pow(1 - progress, 3);
			const current = Math.round(eased * target);
			el.textContent = formatter ? formatter.format(current) : String(current);
			if (progress < 1) requestAnimationFrame(update);
		}

		requestAnimationFrame(update);
	}

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const numbers = entry.target.querySelectorAll<HTMLElement>('.cs-stat-number');
					numbers.forEach(animateNumber);
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.3 }
	);

	document.querySelectorAll('.cs-statistics').forEach((section) => {
		observer.observe(section);
	});
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-statistics {
		display: flex;
		justify-content: center;
		gap: $spacing-16;
		padding: $spacing-12 0;
		margin-bottom: $spacing-12;

		@include media-down(md) {
			flex-direction: column;
			align-items: center;
			gap: $spacing-8;
			padding: $spacing-8 0;
		}
	}

	.cs-stat-block {
		text-align: center;

		.cs-stat-value {
			@include stat-value;
			color: var(--color-primary);
			margin: 0 0 $spacing-2;
		}

		.cs-stat-prefix,
		.cs-stat-suffix,
		.cs-stat-decimal-dot {
			font-size: inherit;
			font-weight: inherit;
			color: inherit;
		}

		.cs-stat-label {
			@include text-m;
			margin: 0;
		}
	}
</style>
