---
import type { PowerBlock } from '@data/case-studies/types.ts';
import SectionBadge from '../SectionBadge.astro';

interface Props {
	badge?: string;
	companyName: string;
	heading?: string;
	blocks: PowerBlock[];
}

const { badge, companyName, heading, blocks } = Astro.props;
---

<section class="cs-power cs-section">
	<SectionBadge text={badge || 'How it works'} color="var(--sl-color-blue-high)" borderColor="var(--sl-color-blue-high)" />
	<h2>{heading ?? `How ThingsBoard powers ${companyName}?`}</h2>
	{blocks.map((block) => (
		<div class="cs-power-block">
			<div class="cs-power-text">
				<h3>{block.title}</h3>
				{typeof block.text === 'string' ? (
					<p set:html={block.text} />
				) : (
					block.text.map((t) => <p set:html={t} />)
				)}
				{block.listItems && block.listItems.length > 0 && (
					<ul>
						{block.listItems.map((item) => <li set:html={item} />)}
					</ul>
				)}
				{block.secondText && <p set:html={block.secondText} />}
			</div>
			<img src={block.image} alt={block.imageAlt} width="900" height="480" loading="lazy" />
		</div>
	))}
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-power {
		> .section-badge {
			margin-bottom: $spacing-3;
		}

		> h2 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-10;
		}
	}

	.cs-power-block {
		display: flex;
		align-items: center;
		gap: $spacing-10;
		margin-bottom: $spacing-10;

		&:last-child {
			margin-bottom: 0;
		}

		&:nth-child(odd) {
			flex-direction: row;
		}

		&:nth-child(even) {
			flex-direction: row-reverse;
		}

		@include media-down(lg) {
			flex-direction: column !important;
			gap: $spacing-6;
		}

		.cs-power-text {
			flex: 1;

			h3 {
				@include card-title;
				color: var(--color-text);
				margin: 0 0 $spacing-4;
			}

			p {
				@include text-s;
				margin: 0;
			}
			
			ul {
				list-style: disc !important;
				padding-left: $spacing-5;
				margin: $spacing-3 0 $spacing-3;

				li {
					@include text-s;
					list-style: disc !important;
					margin-bottom: $spacing-2;

					&::marker {
						color: var(--color-text-muted);
					}

					&:last-child {
						margin-bottom: 0;
					}
				}
			}
		}

		img {
			flex: 0 0 auto;
			width: 480px;
			height: auto;
			border-radius: $radius-lg;
			object-fit: cover;

			@include media-down(xl) {
				width: 400px;
			}

			@include media-down(lg) {
				width: 100%;
			}
		}
	}
</style>
