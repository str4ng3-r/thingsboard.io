---
import type { HelpBlock } from '@data/case-studies/types.ts';
import SectionBadge from '../SectionBadge.astro';

interface Props {
	badge?: string;
	industryName: string;
	blocks: HelpBlock[];
}

const { badge, industryName, blocks } = Astro.props;
---

<section class="cs-help cs-section">
	<SectionBadge text={badge || 'Industry impact'} color="var(--sl-color-purple-high)" borderColor="var(--sl-color-purple-high)" />
	<h2>How ThingsBoard helps {industryName}?</h2>
	{blocks.map((block, index) => (
		<div class:list={['cs-help-block', { 'cs-help-block--reversed': index % 2 !== 0 }]}>
			<div class="cs-help-text">
				<h3>{block.title}</h3>
				<p set:html={block.text} />
				{block.listItems && block.listItems.length > 0 && (
					<ul>
						{block.listItems.map((item) => <li set:html={item} />)}
					</ul>
				)}
				{block.secondText && <p set:html={block.secondText} />}
			</div>
			<div class="cs-help-images">
				{block.images.map((img, imgIndex) => (
					<img
						class={imgIndex === 0 ? 'cs-help-img-back' : 'cs-help-img-front'}
						src={img.src}
						alt={img.alt}
						title={img.title}
						width="776"
						height="776"
						loading="lazy"
					/>
				))}
			</div>
		</div>
	))}
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-help {
		> .section-badge {
			margin-bottom: $spacing-3;
		}

		> h2 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-10;
		}
	}

	.cs-help-block {
		display: flex;
		gap: $spacing-10;
		margin-bottom: $spacing-12;
		align-items: center;

		&:last-child {
			margin-bottom: 0;
		}

		// Zigzag: even blocks reversed
		&--reversed {
			flex-direction: row-reverse;
		}

		@include media-down(lg) {
			flex-direction: column !important;
			gap: $spacing-6;
		}

		.cs-help-text {
			flex: 1;

			h3 {
				@include card-title;
				color: var(--color-text);
				margin: 0 0 $spacing-4;
			}

			p {
				@include text-s;
				margin: 0 0 $spacing-3;

				&:last-child {
					margin-bottom: 0;
				}
			}

			ul {
				list-style: disc !important;
				padding-left: $spacing-5;
				margin: $spacing-3 0 $spacing-3;

				li {
					@include text-s;
					list-style: disc !important;
					margin-bottom: $spacing-2;

					&::marker {
						color: var(--color-text-muted);
					}

					&:last-child {
						margin-bottom: 0;
					}
				}
			}
		}

		.cs-help-images {
			flex: 0 0 auto;
			position: relative;
			width: 300px;
			aspect-ratio: 1.2;

			@include media-down(lg) {
				width: 100%;
				max-width: 300px;
			}

			img {
				position: absolute;
				width: 65%;
				height: auto;
			}

			// Back image — top-left
			.cs-help-img-back {
				top: 0;
				left: 0;
				z-index: 1;
			}

			// Front image — overlapping, bottom-right
			.cs-help-img-front {
				bottom: 0;
				right: 0;
				z-index: 2;
			}
		}
	}
</style>
