---
import '@astrojs/starlight/style/markdown.css';
import { Code } from '@astrojs/starlight/components';
import ImageGallery from '@components/ImageGallery.astro';
import { resolveImage } from '@models/iot-hub';
import { getMarkdownProcessor } from '@util/markdown-processor';

// Renders IoT Hub listing readme markdown. Plain prose flows through the
// shared markdown processor and renders via set:html; fenced code blocks
// (and any future registered patterns) are extracted *before* processing
// and rendered with their matching Astro component instead — see the
// `Slot` registry below.
//
// To add a new pattern:
//   1. Add a `kind` + `props` shape to the `Slot` union.
//   2. Write a detector that scans the raw markdown, pushes a slot per
//      match, and replaces the matched text with `slotComment(i)`.
//   3. Add a case to the render switch in the template below.

interface Props {
	markdown: string | null | undefined;
}

const { markdown } = Astro.props;

// Registry of slot kinds we know how to render. Each slot stores the
// props the matching Astro component will be invoked with.
type CodeSlotProps = { code: string; lang?: string; meta?: string };
type GalleryImage = { src: string; alt: string; caption?: string };
type GallerySlotProps = { images: GalleryImage[] };
type Slot =
	| { kind: 'code'; props: CodeSlotProps }
	| { kind: 'gallery'; props: GallerySlotProps };

// Sentinel: HTML comments survive markdown→HTML conversion unmodified, so
// we can splice slots back into the rendered HTML by plain string matching.
const SENTINEL_PREFIX = 'ih-slot-';
const slotComment = (i: number) => `<!--${SENTINEL_PREFIX}${i}-->`;
const SLOT_RE = new RegExp(`<!--${SENTINEL_PREFIX}(\\d+)-->`, 'g');

// --- Detectors ---------------------------------------------------------------

// Fenced code blocks (```lang …meta\n…\n```). Tilde fences accepted too.
// The opening fence string is back-referenced (`\2`) so the closing fence has
// to match it exactly — keeps nested-fence outer blocks intact.
const FENCED_CODE_RE = /^([ \t]*)(`{3,}|~{3,})[ \t]*([^\n`]*?)\n([\s\S]*?)\n\1\2[ \t]*$/gm;
// Kramdown attribute-list residue from the legacy docs site — used there to
// attach a `copy-code` class to the preceding block. Meaningless here, so we
// scrub it from extracted code bodies (both on its own line and inline).
const COPY_CODE_LINE_RE = /^[ \t]*\{:copy-code}[ \t]*\n?/gm;
const COPY_CODE_INLINE_RE = /[ \t]*\{:copy-code}/g;
function cleanCodeContent(code: string): string {
	return code.replace(COPY_CODE_LINE_RE, '').replace(COPY_CODE_INLINE_RE, '');
}
function extractCodeBlocks(src: string, slots: Slot[]): string {
	return src.replace(FENCED_CODE_RE, (_full, _indent, _fence, info: string, code: string) => {
		const trimmed = (info ?? '').trim();
		const spaceIdx = trimmed.search(/\s/);
		const lang = (spaceIdx === -1 ? trimmed : trimmed.slice(0, spaceIdx)) || 'plaintext';
		const userMeta = spaceIdx === -1 ? '' : trimmed.slice(spaceIdx + 1).trim();
		const cleaned = cleanCodeContent(code);
		// Always cap to 20 lines via expressive-code's maxLines meta token, and
		// add line numbers for multi-line snippets. Author-supplied meta tokens
		// (e.g. `title="…"`) come first so they aren't overridden.
		const tokens: string[] = [];
		if (userMeta) tokens.push(userMeta);
		if (cleaned.includes('\n')) tokens.push('showLineNumbers');
		tokens.push('maxLines=20');
		const meta = tokens.join(' ');
		const i = slots.push({ kind: 'code', props: { code: cleaned, lang, meta } }) - 1;
		// Blank lines around the comment so markdown parses it as its own block.
		return `\n\n${slotComment(i)}\n\n`;
	});
}

// Rewrite relative `/api/resources/…` paths (the IoT Hub API uses these for
// listing-uploaded images) into absolute URLs. The lookbehind skips paths
// already part of an absolute URL like `https://host/api/resources/…`.
const RESOURCE_PATH_RE = /(?<![:\w])(\/api\/resources\/[^\s)"'>]+)/g;
function rewriteResourceUrls(src: string): string {
	return src.replace(RESOURCE_PATH_RE, (_m, path: string) => resolveImage(path) ?? path);
}

// Image galleries: `${images.gallery({src:'…',alt:'…',caption:'…'}, {src:'…'}, …)}`.
// Ported from `resolveVariables` in the platform's iot-hub-markdown.component.ts:
// outer regex captures everything between the parens; inner regex pulls out
// each `{…}` object literal; per-field regexes extract the quoted strings
// (preserving the quote type via back-reference so single- and double-quoted
// values both work). Run AFTER rewriteResourceUrls so any `/api/resources/…`
// paths inside `src:` fields are already absolute.
const GALLERY_RE = /\$\{\s*images\.gallery\(([\s\S]*?)\)\s*}/g;
const GALLERY_OBJ_RE = /\{[\s\S]*?}/g;
const GALLERY_SRC_RE = /src\s*:\s*(['"])((?:(?!\1).)*)\1/;
const GALLERY_ALT_RE = /alt\s*:\s*(['"])((?:(?!\1).)*)\1/;
const GALLERY_CAPTION_RE = /caption\s*:\s*(['"])((?:(?!\1).)*)\1/;
function extractImageGalleries(src: string, slots: Slot[]): string {
	return src.replace(GALLERY_RE, (_full, inner: string) => {
		const objects = inner.match(GALLERY_OBJ_RE) ?? [];
		const images: GalleryImage[] = [];
		for (const obj of objects) {
			const imgSrc = obj.match(GALLERY_SRC_RE)?.[2] ?? '';
			if (!imgSrc) continue;
			const item: GalleryImage = {
				src: imgSrc,
				alt: obj.match(GALLERY_ALT_RE)?.[2] ?? '',
			};
			const caption = obj.match(GALLERY_CAPTION_RE)?.[2];
			if (caption) item.caption = caption;
			images.push(item);
		}
		// Drop the marker entirely if no valid images were found, rather than
		// rendering an empty gallery surface.
		if (images.length === 0) return '';
		const i = slots.push({ kind: 'gallery', props: { images } }) - 1;
		return `\n\n${slotComment(i)}\n\n`;
	});
}

// --- Pipeline ----------------------------------------------------------------

const slots: Slot[] = [];
const parts: Array<{ kind: 'html'; html: string } | { kind: 'slot'; slot: Slot }> = [];

if (markdown && markdown.trim().length > 0) {
	// 1. Extract code blocks first so later detectors and the URL rewrite
	//    below can't accidentally reach into code bodies.
	let src = markdown;
	src = extractCodeBlocks(src, slots);

	// 2. Rewrite IoT Hub resource URLs in the surviving prose. Done BEFORE
	//    gallery extraction so any `/api/resources/…` paths inside gallery
	//    `src:` fields are already absolute by the time we parse them.
	src = rewriteResourceUrls(src);

	// 3. Extract any remaining patterns. Add new detectors here.
	src = extractImageGalleries(src, slots);

	// 4. Markdown → HTML.
	const processor = await getMarkdownProcessor();
	const { code: html } = await processor.render(src);

	// 5. Walk the HTML, alternating between html chunks and slot invocations.
	SLOT_RE.lastIndex = 0;
	let last = 0;
	let m: RegExpExecArray | null;
	while ((m = SLOT_RE.exec(html))) {
		if (m.index > last) parts.push({ kind: 'html', html: html.slice(last, m.index) });
		const slot = slots[Number(m[1])];
		if (slot) parts.push({ kind: 'slot', slot });
		last = m.index + m[0].length;
	}
	if (last < html.length) parts.push({ kind: 'html', html: html.slice(last) });
}
---

{
	parts.length > 0 && (
		<div class="sl-markdown-content">
			{parts.map((p) => {
				if (p.kind === 'html') return <Fragment set:html={p.html} />;
				switch (p.slot.kind) {
					case 'code':
						return <Code {...p.slot.props} />;
					case 'gallery':
						return <ImageGallery {...p.slot.props} />;
					// Future: more cases here.
					default:
						return null;
				}
			})}
		</div>
	)
}

<style lang="scss">
	@use '~/styles/_variables.scss' as *;
	
	.sl-markdown-content {

		:global(p) { 
			line-height: var(--sl-line-height);
			-webkit-font-smoothing: antialiased;
			color: var(--sl-color-text);
			font-size: var(--sl-font-size);
		}

		:global(h1), :global(h2), :global(h3), :global(h4), :global(h5), :global(h6) {
			font-size: 24px;
			font-weight: 600;
			line-height: 32px;
			letter-spacing: 0.1px;
			color: var(--sl-color-text);
			margin: 0;
			padding: 0;
		}

		:global(> h1), :global(> h2), :global(> h3), :global(> h4), :global(> h5), :global(> h6) {
			padding: 0 0 6px;
			margin-top: 20px;
		}

		:global(h1) {
			font-size: 32px;
			line-height: 48px;
			padding-right: 0;
		}

		:global(ul), :global(li) {
			list-style: disc;
		}

		:global(> p), :global(> div) {
			padding-left: 0;
			padding-right: 0;
		}

		:global(p + p) {
			margin-top: 8px;
		}

		:global(h1 + p), :global(h2 + p), :global(h3 + p),
		:global(h1 + ul), :global(h2 + ul), :global(h3 + ul),
		:global(h1 + ol), :global(h2 + ol), :global(h3 + ol) {
			margin-top: 8px;
		}

		:global(ul, ol) {
			padding-left: 21px;
			padding-right: 0;
			margin: 0;
			font-size: 16px;
			line-height: 24px;
			letter-spacing: 0.2px;

			:global(+ h1), :global(+ h2), :global(+ h3), :global(+ h4), :global(+ h5), :global(+ h6) {
				padding-top: 0;
				margin-top: 20px;
			}
		}

		:global(ul) {
			margin-top: 8px;
			margin-bottom: 8px;
		}

		:global(ul), :global(li) {
			list-style: disc;
		}

		:global(img) {
			max-width: 100%;
		}

		:global(li > p) {
			margin: 0;
		}

		:global(.tb-callout) {
			display: flex;
			align-items: flex-start;
			gap: 10px;
			padding: 12px 16px;
			border-radius: 4px;
			border: 1px solid;
			margin: 12px 0;
			font-size: 16px;
			line-height: 24px;

			:global(.tb-callout-icon) {
				font-size: 20px;
				flex-shrink: 0;
			}

			&.tb-callout-note {
				background: #e3f2fd;
				border-color: #90caf9;
				color: #1565c0;
			}

			&.tb-callout-warn {
				background: #fff8e1;
				border-color: #ffe082;
				color: #f57f17;
			}

			&.tb-callout-error {
				background: #fce4ec;
				border-color: #ef9a9a;
				color: #c62828;
			}
		}
	}
</style>
