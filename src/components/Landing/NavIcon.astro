---
// Inlines a navigation icon SVG so its `currentColor` fills can be themed
// from CSS (e.g. menu primary in dark mode). Replacing `<img>` here is what
// allows `color:` to flow into the SVG — `<img src="...svg">` is opaque to
// CSS color rules, so we read the SVG content at build time and emit it
// directly into the DOM.
const icons = import.meta.glob<string>('/src/assets/images/landings/nav/*.svg', {
	eager: true,
	query: '?raw',
	import: 'default',
});

interface Props {
	src: string | undefined;
	size?: number;
	alt?: string;
}

const { src, size = 32, alt } = Astro.props;

/** Escape a string for safe interpolation into an HTML attribute value. */
const attr = (s: string) =>
	s
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#39;');

let svg = '';
if (src && icons[src]) {
	svg = icons[src];
	// Strip XML declaration if present
	svg = svg.replace(/<\?xml[^>]*\?>\s*/, '');
	// Match the previous `<img width=N height=N>` + CSS `height: fit-content`
	// rendering. The old `<img>` was constrained to `size` wide by the
	// `width=` attribute, but `height: fit-content` made the height fall
	// back to the SVG's intrinsic height — so a 34×44 viewBox icon was
	// drawn in a `size`-wide × intrinsic-tall box, with content scaled
	// to fit (preserveAspectRatio default = xMidYMid meet). Replicating
	// here: strip the SVG's own width/height, set our `width="${size}"`,
	// and DON'T set height — the inline svg then computes height from
	// viewBox + width via the intrinsic aspect ratio.
	svg = svg.replace(/<svg([^>]*)>/, (_match, attrs: string) => {
		const cleaned = attrs.replace(/\s*(width|height)="[^"]*"/g, '').trim();
		const ariaAttrs = alt ? ` role="img" aria-label="${attr(alt)}"` : ' aria-hidden="true"';
		return `<svg ${cleaned} class="nav-icon" width="${size}"${ariaAttrs}>`;
	});
}
---

{svg && <Fragment set:html={svg} />}
