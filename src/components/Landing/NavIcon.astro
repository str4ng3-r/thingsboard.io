---
// Navigation icon rendered as a same-origin sprite reference. The mega-menu
// carries 50+ icons on every page; referencing `public/nav-sprite.svg` via
// `<use>` keeps that markup out of the HTML stream (one cached file instead)
// while `currentColor` still inherits into the sprite content, so CSS
// `color:` theming (e.g. menu primary in dark mode) keeps working.
//
// The sprite is generated from `src/assets/images/landings/nav/*.svg` —
// after adding or editing an icon, re-run `pnpm generate:nav-sprite`.
//
// Sizing matches the previous inline rendering: `width` is set, height is
// left to the browser to compute from the icon's own viewBox aspect ratio.
const icons = import.meta.glob<string>('/src/assets/images/landings/nav/*.svg', {
	eager: true,
	query: '?raw',
	import: 'default',
});

interface Props {
	src: string | undefined;
	size?: number;
	alt?: string;
}

const { src, size = 32, alt } = Astro.props;

let viewBox: string | undefined;
let symbolId = '';
if (src && icons[src]) {
	viewBox = icons[src].match(/viewBox="([^"]+)"/)?.[1];
	const name = src.split('/').pop()?.replace(/\.svg$/, '') ?? '';
	if (name) symbolId = `nav-${name}`;
}
---

{
	symbolId && (
		<svg
			class="nav-icon"
			width={size}
			viewBox={viewBox}
			role={alt ? 'img' : undefined}
			aria-label={alt || undefined}
			aria-hidden={alt ? undefined : 'true'}
		>
			<use href={`/nav-sprite.svg#${symbolId}`} />
		</svg>
	)
}
