---
// Navigation icon rendered as a same-origin sprite reference. The mega-menu
// carries 50+ icons on every page; referencing `public/nav-sprite.svg` via
// `<use>` keeps that markup out of the HTML stream (one cached file instead)
// while `currentColor` still inherits into the sprite content, so CSS
// `color:` theming (e.g. menu primary in dark mode) keeps working.
//
// Symbol id and viewBox come from the manifest that is generated TOGETHER
// with the sprite (scripts/generate-nav-sprite.mjs, run automatically before
// builds), so the reference and the geometry can't drift apart. After adding
// or editing an icon in dev, re-run `pnpm generate:nav-sprite`.
//
// Sizing matches the previous inline rendering: `width` is set, height is
// left to the browser to compute from the icon's viewBox aspect ratio.
import spriteManifest from '../../assets/images/landings/nav-sprite.manifest.json';

interface Props {
	src: string | undefined;
	size?: number;
	alt?: string;
}

const { src, size = 32, alt } = Astro.props;

const name = src?.split('/').pop()?.replace(/\.svg$/, '') ?? '';
const entry = (spriteManifest.icons as Record<string, { id: string; viewBox: string }>)[name];
---

{
	entry && (
		<svg
			class="nav-icon"
			width={size}
			viewBox={entry.viewBox}
			role={alt ? 'img' : undefined}
			aria-label={alt || undefined}
			aria-hidden={alt ? undefined : 'true'}
		>
			<use href={`/nav-sprite.svg#${entry.id}`} />
		</svg>
	)
}
