---
import SmartImage from '@components/SmartImage.astro';
import ReadMoreLink from './ReadMoreLink.astro';

interface FeatureItem {
	heading: string;
	description: string;
	readMoreHref: string;
	readMoreText?: string;
}

interface Props {
	left: FeatureItem;
	right: FeatureItem;
	imageSrc: string;
	imageAlt: string;
	imageWidth?: number;
	imageHeight?: number;
	bgId?: string;
	bgDivs?: string[];
	variant?: 'default' | 'pe';
	id?: string;
}

const { left, right, imageSrc, imageAlt, imageWidth, imageHeight, bgId, bgDivs, variant = 'default', id } = Astro.props;
const hasPseudoBg = !bgId;
---

<section class:list={['dual-feature-section', { 'has-pseudo-bg': hasPseudoBg }]} {id}>
	<div class="main-div">
		{bgId && (
			<div id={bgId}>
				{bgDivs?.map((cls) => <div class={cls} />)}
			</div>
		)}
		<div class="triple-block">
			<div class="feature-des left-textblock">
				<h3 class="phrase-heading">{left.heading}</h3>
				<p>{left.description}</p>
				<ReadMoreLink href={left.readMoreHref} ariaLabel={left.readMoreText} variant={variant} />
			</div>
			<div class="feature-img">
				<SmartImage
					src={imageSrc}
					alt={imageAlt}
					width={imageWidth}
					height={imageHeight}
					loading="lazy"
				/>
			</div>
			<div class="feature-des right-textblock">
				<h3 class="phrase-heading">{right.heading}</h3>
				<p>{right.description}</p>
				<ReadMoreLink href={right.readMoreHref} ariaLabel={right.readMoreText} variant={variant} />
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	.dual-feature-section {
		position: relative;
		width: 100%;
		overflow: visible;

		// Skewed light-grey background — only when no bgId DOM div is provided
		&.has-pseudo-bg::before {
			content: '';
			position: absolute;
			inset: 0;
			width: 100vw;
			left: 50%;
			transform: translateX(-50%) skewY(-3deg);
			background-color: #f4f4f4;
			z-index: 0;
		}

		.main-div {
			position: relative;
			z-index: 1;
			max-width: 1200px;
			margin: 0 auto;
			padding: 5rem 1.875rem;

			@media screen and (min-width: 1500px) {
				max-width: 1400px;
			}

			@media screen and (max-width: 768px) {
				padding: 3rem 1.25rem;
			}
		}

		.triple-block {
			display: flex;
			align-items: center;
			gap: 3rem;

			@media screen and (max-width: 1024px) {
				flex-direction: column;
				gap: 2.5rem;
			}
		}

		.feature-des {
			flex: 1;
			min-width: 0;

			.phrase-heading {
				font-size: $font-size-3xl;
				font-weight: $font-weight-bold;
				color: $color-text-primary;
				margin: 0 0 1.25rem;
				line-height: 1.3;

				@media screen and (max-width: 768px) {
					font-size: $font-size-2xl;
				}
			}

			p {
				font-size: $font-size-lg;
				line-height: 1.7;
				color: $color-text-secondary;
				margin: 0 0 1.75rem;
			}
		}

		.feature-img {
			flex: 0 0 auto;
			display: flex;
			align-items: center;
			justify-content: center;

			:global(img) {
				max-width: 100%;
				height: auto;
				border-radius: $radius-md;
				box-shadow:
					0 50px 50px -20px rgba(0, 0, 0, 0.15),
					0 0 30px 0 rgba(0, 0, 0, 0.1);
			}

			@media screen and (max-width: 1024px) {
				order: 3;
			}
		}
	}
</style>