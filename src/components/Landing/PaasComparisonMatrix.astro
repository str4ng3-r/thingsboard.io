---
import { Icon } from 'astro-icon/components';

interface MatrixRow {
	label: string;
	href?: string;
	ce: boolean | string;
	pe: boolean | string;
	cloud: boolean | string;
}

const rows: MatrixRow[] = [
	{ label: 'Asset management & Data collection', ce: true, pe: true, cloud: true },
	{ label: 'End-user real-time dashboards', ce: true, pe: true, cloud: true },
	{ label: 'Customizable rule chains, widgets', ce: true, pe: true, cloud: true },
	{ label: 'MQTT, HTTP, CoAP, OPC-UA transport', ce: true, pe: true, cloud: true },
	{ label: 'Integrations with BigData systems', ce: true, pe: true, cloud: true },
	{ label: 'NB-IoT, SigFox, LoRaWAN support', ce: 'Basic', pe: 'Advanced', cloud: 'Advanced' },
	{
		label: 'Rule Engine: Components',
		href: '/docs/user-guide/rule-engine-2-0/overview/',
		ce: 'Basic',
		pe: 'Advanced',
		cloud: 'Advanced',
	},
	{
		label: 'Entity groups',
		href: '/docs/user-guide/groups/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'Advanced RBAC for IoT',
		href: '/docs/user-guide/rbac/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'Scheduler',
		href: '/docs/user-guide/scheduler/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'Reporting',
		href: '/docs/paas/user-guide/reporting/reporting-key-concepts/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'White-labeling',
		href: '/docs/user-guide/white-labeling/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'CSV/XLS data export',
		href: '/docs/user-guide/csv-xls-data-export/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'Platform Integrations',
		href: '/docs/user-guide/integrations/',
		ce: false,
		pe: true,
		cloud: true,
	},
	{
		label: 'Domain management',
		href: '/docs/paas/domains/',
		ce: false,
		pe: false,
		cloud: true,
	},
];
---

<section id="matrix">
	<div class="matrix-inner">
		<div class="backg-matrix" aria-hidden="true">
			<div class="community"><div class="coln"></div></div>
			<div class="prof"><div class="coln"></div></div>
			<div class="cloud"><div class="coln"></div></div>
		</div>

		<h2>Feature Comparison Matrix</h2>

		<table>
			<thead>
				<tr>
					<td></td>
					<th scope="col">Community<br />Edition</th>
					<th scope="col">Professional<br />Edition</th>
					<th scope="col">Cloud</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row) => (
						<tr>
							<th scope="row">
								{row.href ? (
								<a href={row.href}>
									{row.label}
									<Icon name="tabler:help-circle-filled" class="faq-icon" aria-hidden="true" />
								</a>
							) : row.label}
							</th>
							{(['ce', 'pe', 'cloud'] as const).map((col) => {
								const val = row[col];
								return (
									<td>
										{val === true && (
											<Icon name="fa-solid:check" aria-label="Available" />
										)}
										{val === false && (
											<Icon name="fa-solid:times" class="disabled" aria-label="Not available" />
										)}
										{typeof val === 'string' && val}
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#matrix {
		margin: 60px calc(-50vw + 50%) 0;
		padding: 72px max(calc(50vw - 50%), 1.25rem) 112px;
		position: relative;
	}

	.matrix-inner {
		position: relative;
		max-width: 1400px;
		margin: 0 auto;
	}

	h2 {
		color: $color-dark;
		font-weight: $font-weight-semibold;
		font-size: 22px;
		line-height: 40px;
		margin: 0 0 0;
		position: relative;
		z-index: 1;

		@include media-up(md) {
			font-size: $font-size-6xl;
			line-height: 63px;
		}
	}

	// ── Decorative column backgrounds ─────────────────────────────
	.backg-matrix {
		position: relative;
		margin: 0 -20px;
		width: calc(100% + 40px);

		.cloud,
		.prof,
		.community {
			padding: 0 7px;
			width: 20%;
			position: absolute;
			z-index: 0;
			top: 127px;
		}

		.coln {
			height: 1156px;
			border-radius: $radius-md;
			background-origin: border-box;
		}

		.cloud {
			right: 0;

			.coln {
				border: 2px solid $color-primary;
				box-shadow: 0 50px 50px -20px rgba(0, 0, 0, 0.15), 0 0 30px 0 rgba(0, 0, 0, 0.1);
				// top 108px = 2px top-border + 106px head area → full blue fill
				background-image: linear-gradient(
					to bottom,
					$color-primary 108px,
					transparent 108px
				);
			}
		}

		.prof {
			right: 20%;

			.coln {
				border: 2px solid #a9dfbf;
				// 2px line at 108–110px from outer border edge
				background-image: linear-gradient(
					to bottom,
					transparent 108px,
					#a9dfbf 108px,
					#a9dfbf 110px,
					transparent 110px
				);
			}
		}

		.community {
			right: 40%;

			.coln {
				border: 2px solid #acbbcc;
				background-image: linear-gradient(
					to bottom,
					transparent 108px,
					#acbbcc 108px,
					#acbbcc 110px,
					transparent 110px
				);
			}
		}
	}

	// ── Table ─────────────────────────────────────────────────────
	.backg-matrix {
		@include media-down(md) {
			display: none;
		}
	}

	table {
		width: calc(100% + 40px);
		margin: 64px -20px 16px;
		table-layout: fixed;
		border: none;
		border-collapse: collapse;
		position: relative;
		z-index: 1;

		@include media-down(md) {
			width: 100%;
			margin-left: 0;
			margin-right: 0;
		}

		:global(svg) {
			font-size: 25px;
			width: 25px;
			height: 25px;

			&.disabled {
				opacity: 0.2;
			}

			@include media-down(md) {
				width: 18px;
				height: 18px;
			}
		}
	}

	thead tr {
		height: 152px;

		@include media-down(md) {
			height: 80px;
		}

		td {
			width: 40%;
		}

		th {
			width: 20%;
			text-align: center;
			vertical-align: middle;
			font-weight: $font-weight-semibold;
			font-size: 11px;
			padding: 0 0 40px;
			color: $color-dark;

			@include media-up(md) {
				font-size: 20px;
			}

			@include media-down(md) {
				padding: 0 4px 16px;
				font-size: 10px;
				line-height: 1.3;
			}

			// CE column
			&:nth-child(2) {
				color: $color-primary-dark;
			}

			// PE column
			&:nth-child(3) {
				color: #27ae60;
			}

			// Cloud column — white text over blue bg
			&:nth-child(4) {
				color: $color-white;

				@include media-down(md) {
					color: $color-primary;
				}
			}
		}
	}

	tbody tr {
		background-color: transparent;
		height: 64px;

		@include media-down(md) {
			height: auto;
			min-height: 48px;
		}

		th {
			font-weight: $font-weight-semibold;
			font-size: 12px;
			padding-left: 20px;
			padding-right: 12px;
			text-align: left;
			color: $color-dark;
			word-wrap: break-word;

			a {
				color: $color-dark;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}

				:global(.faq-icon) {
					display: inline-block;
					width: 16px;
					height: 16px;
					font-size: 16px;
					vertical-align: super;
					margin-left: 3px;
					opacity: 0.5;
				}
			}

			@include media-up(md) {
				font-size: 18px;
				padding-right: 48px;
			}

			@include media-down(md) {
				padding: 8px 8px 8px 8px;
				font-size: 11px;
			}
		}

		td {
			text-align: center;
			font-weight: $font-weight-semibold;
			font-size: 11px;

			@include media-up(md) {
				font-size: 20px;
			}

			@include media-down(md) {
				font-size: 11px;
				padding: 8px 2px;
			}

			// CE column
			&:nth-child(2) {
				color: $color-primary-dark;
			}

			// PE column
			&:nth-child(3) {
				color: #27ae60;
			}

			// Cloud column
			&:nth-child(4) {
				color: $color-primary;
			}
		}
	}
</style>