---
/**
 * Renders a code block with product-aware hostname substitution.
 *
 * Use placeholders in the `code` prop:
 *   {MQTT_HOST}       — MQTT broker host for shell ($THINGSBOARD_HOST or mqtt.thingsboard.cloud)
 *   {COAP_HOST}       — CoAP server host for shell ($THINGSBOARD_HOST or coap.thingsboard.cloud)
 *   {HTTP_HOST}       — HTTP host for shell ($THINGSBOARD_HOST or thingsboard.cloud)
 *   {LWM2M_HOST}      — LwM2M host for shell ($THINGSBOARD_HOST or lwm2m.thingsboard.cloud)
 *   {BASE_URL}        — REST API base URL (http://localhost:8080 or https://thingsboard.cloud)
 *   {HOST_NAME}       — Generic hostname (localhost or thingsboard.cloud)
 *   {MQTT_HOST_NAME}  — MQTT hostname without $ prefix (127.0.0.1 or mqtt.thingsboard.cloud)
 *   {HTTP_URL_PREFIX}  — Protocol + host for descriptive URLs (http(s)://THINGSBOARD_HOST or https://thingsboard.cloud)
 *   {COAP_HOST_LABEL}  — Hostname for descriptive text (THINGSBOARD_HOST or coap.thingsboard.cloud)
 *   {COAP_URL_PREFIX}  — Protocol + host for descriptive CoAP URLs (coap(s)://THINGSBOARD_HOST or coap(s)://coap.thingsboard.cloud)
 *   {CA_CERT}          — CA root certificate filename (ca-root.pem or tb-cloud-root-ca.pem)
 */
import { Code } from '@astrojs/starlight/components';
import { getHostConfig } from '~/data/hosts';
import type { Products } from '~/models/site.models';

interface Props {
	product: Products;
	code: string;
	lang: string;
	meta?: string;
}

const { product, code, lang, meta } = Astro.props;
const hosts = getHostConfig(product);

const replacements: Record<string, string> = hosts.isSelfHosted
	? {
			'{MQTT_HOST}': '$THINGSBOARD_HOST',
			'{COAP_HOST}': '$THINGSBOARD_HOST',
			'{HTTP_HOST}': '$THINGSBOARD_HOST',
			'{LWM2M_HOST}': '$THINGSBOARD_HOST',
			'{BASE_URL}': 'http://localhost:8080',
			'{HOST_NAME}': 'localhost',
			'{MQTT_HOST_NAME}': '127.0.0.1',
			'{HTTP_URL_PREFIX}': 'http(s)://THINGSBOARD_HOST',
			'{COAP_HOST_LABEL}': 'THINGSBOARD_HOST',
			'{COAP_URL_PREFIX}': 'coap(s)://THINGSBOARD_HOST',
			'{CA_CERT}': 'ca-root.pem',
		}
	: {
			'{MQTT_HOST}': hosts.mqttHostName,
			'{COAP_HOST}': hosts.coapHostName,
			'{HTTP_HOST}': hosts.hostName,
			'{LWM2M_HOST}': hosts.lwm2mHostName,
			'{BASE_URL}': hosts.baseUrl,
			'{HOST_NAME}': hosts.hostName,
			'{MQTT_HOST_NAME}': hosts.mqttHostName,
			'{HTTP_URL_PREFIX}': 'https://' + hosts.hostName,
			'{COAP_HOST_LABEL}': hosts.coapHostName,
			'{COAP_URL_PREFIX}': 'coap(s)://' + hosts.coapHostName,
			'{CA_CERT}': 'tb-cloud-root-ca.pem',
		};

let resolved = code;
for (const [placeholder, value] of Object.entries(replacements)) {
	resolved = resolved.replaceAll(placeholder, value);
}
---

<Code code={resolved} lang={lang} meta={meta} />
