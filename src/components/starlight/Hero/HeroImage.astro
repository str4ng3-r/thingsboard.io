---
import fs from 'node:fs';
import { join } from 'node:path';
import { docsLink, Products } from '~/models/site.models';

export interface Props {
	product: Products;
}

const { product } = Astro.props;

const productColor: Partial<Record<Products, string>> = {
	[Products.PE]: '#00695C',
	[Products.PAAS]: '#00695C',
	[Products.PAAS_EU]: '#00695C',
	[Products.GW]: '#6D28D9',
};
const color = productColor[product] ?? '#305680';

const svgPath = join(process.cwd(), 'public', 'hero', 'hero.svg');
let svg = fs.readFileSync(svgPath, 'utf-8');

const links = {
	dashboards: docsLink(product, 'user-guide/dashboards/'),
	users: docsLink(product, 'user-guide/users/'),
	alarms: docsLink(product, 'user-guide/alarms/'),
	devices: docsLink(product, 'user-guide/devices/'),
	widgets: docsLink(product, 'user-guide/widgets/'),
};

// Substitute link placeholders defined in the SVG
for (const [key, href] of Object.entries(links)) {
	svg = svg.replaceAll(`{{links.${key}}}`, href);
}
---

<div class="hero-image not-content" style={`color: ${color};`} set:html={svg} />

<style>
	.hero-image {
		display: none;
	}

	@media (min-width: 78rem) {
		.hero-image {
			display: flex;
			align-items: center;
			justify-self: end;
			align-self: center;
			padding: 2rem 2rem 2rem 0;
			pointer-events: none;
			height: 43.75rem;
		}

		.hero-image :global(svg) {
			width: 100%;
			max-width: 40rem;
			height: auto;
			filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.2));
			display: block;
		}

		.hero-image :global(svg a) {
			pointer-events: all;
			cursor: pointer;
		}
	}

	@media (min-width: 77.9375rem) and (max-width: 100rem) {
		.hero-image {
			align-items: end;
		}
	}
</style>
