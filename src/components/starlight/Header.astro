---
import HeaderContent from '../Landing/HeaderContent.astro';
import { Products } from '@models/site.models';

const pathname = Astro.url.pathname;

function getGitHubPlatform(path: string): Products {
	if (path.includes('/docs/iot-gateway/')) return Products.GW;
	if (path.includes('/docs/edge/pe/') || path.includes('/docs/edge/')) return Products.EDGE;
	if (path.includes('/docs/mqtt-broker/pe/') || path.includes('/docs/mqtt-broker/'))
		return Products.TBMQ;
	return Products.CE;
}

// `BaseStarlightLayout` passes the page's product via Astro.locals so
// the GitHub button targets the right repo; everywhere else the
// platform is inferred from the URL (docs routes carry the product as
// a path prefix).
const override = (Astro.locals as unknown as Record<string, unknown>).bslGitHubPlatform as
	| Products
	| undefined;
const gitHubPlatform = override ?? getGitHubPlatform(pathname);
---

<HeaderContent gitHubPlatform={gitHubPlatform} />
