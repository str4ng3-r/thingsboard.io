---
import HeaderContent from '../Landing/HeaderContent.astro';
import { Products } from '@models/site.models';

const pathname = Astro.url.pathname;

function getGitHubPlatform(path: string): Products {
	if (path.includes('/docs/iot-gateway/')) return Products.GW;
	if (path.includes('/docs/edge/pe/') || path.includes('/docs/edge/')) return Products.EDGE;
	if (path.includes('/docs/mqtt-broker/pe/') || path.includes('/docs/mqtt-broker/'))
		return Products.TBMQ;
	return Products.CE;
}

const gitHubPlatform = getGitHubPlatform(pathname);
---

<HeaderContent gitHubPlatform={gitHubPlatform} />
