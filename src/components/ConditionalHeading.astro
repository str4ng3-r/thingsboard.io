---
/**
 * ConditionalHeading — renders a heading with the full Starlight anchor-link structure.
 *
 * Intended for use inside JSX conditional expressions in _includes files where a heading
 * must be shown only for specific products. The accompanying `rehype-mdx-include-headings`
 * plugin reads <ConditionalHeading> from the raw include source and injects the heading into
 * the page TOC only for products that match the `exclude`/`showFor` filter.
 *
 * Props:
 *   level    — heading level 2–6 (default: 3)
 *   id       — anchor id, e.g. "export-dashboard" (required)
 *   exclude  — comma-separated product ids to EXCLUDE, e.g. "ce" (parsed by plugin only)
 *   showFor  — comma-separated product ids to INCLUDE (parsed by plugin only)
 *
 * Usage in MDX _includes:
 *   {props.product !== Products.CE && (
 *     <>
 *       <ConditionalHeading level={3} id="export-dashboard" exclude="ce">Export dashboard</ConditionalHeading>
 *       <p>Content…</p>
 *     </>
 *   )}
 */
interface Props {
	level?: 2 | 3 | 4 | 5 | 6;
	id: string;
	exclude?: string;
	showFor?: string;
}

const { level = 3, id } = Astro.props;
const Tag = `h${level}` as 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
---

<div class={`sl-heading-wrapper level-h${level}`}>
	<Tag id={id}><slot /></Tag><a class="sl-anchor-link" href={`#${id}`}
		><span aria-hidden="true" class="sl-anchor-icon"
			><svg width="16" height="16" viewBox="0 0 24 24"
				><path
					fill="currentcolor"
					d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 0 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 1 0-1.42-1.42Zm8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 0 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0 2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 1 0 1.42 1.42l3.88-3.89a4.49 4.49 0 0 0 0-6.33ZM8.83 15.17a1 1 0 0 0 1.1.22 1 1 0 0 0 .32-.22l4.92-4.92a1 1 0 0 0-1.42-1.42l-4.92 4.92a1 1 0 0 0 0 1.42Z"
				></path></svg
			></span
		><span class="sr-only">Section titled <slot /></span></a
	>
</div>