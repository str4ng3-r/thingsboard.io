---
import { allPages } from '~/content';
import {
	getLanguageFromURL,
	getVersionFromURL,
	getPageSlugFromURL,
	getVersionPrefix,
	supportedLanguages,
	switchLanguageWithFallback,
	type SupportedLanguage,
} from '~/util/path-utils';

const currentLang = getLanguageFromURL(Astro.url.pathname);

// Build a set of all existing page IDs for fast lookup
const existingPageIds = new Set(allPages.map((page) => page.id));

const options = (Object.entries(supportedLanguages) as [SupportedLanguage, { label: string; prefix: string }][]).map(
	([key, { label }]) => {
		const { url, isFallback } = switchLanguageWithFallback(Astro.url.pathname, key, existingPageIds);
		return {
			value: url,
			selected: key === currentLang,
			label: isFallback ? `${label} (EN)` : label,
			isFallback,
		};
	}
);
---

<language-select>
	<label>
		<span class="sr-only">Language</span>
		<svg aria-hidden="true" class="icon label-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
			<path d="M12.87 15.07l-2.54-2.51.03-.03c1.74-1.94 2.98-4.17 3.71-6.53H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z"></path>
		</svg>
		<select autocomplete="off">
			{options.map(({ value, selected, label }) => (
				<option value={value} selected={selected}>{label}</option>
			))}
		</select>
		<svg aria-hidden="true" class="icon caret" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
			<path d="M7 10l5 5 5-5z"></path>
		</svg>
	</label>
</language-select>

<script>
	class LanguageSelect extends HTMLElement {
		constructor() {
			super();
			const select = this.querySelector('select');
			if (select) {
				select.addEventListener('change', (e) => {
					if (e.currentTarget instanceof HTMLSelectElement) {
						const newPath = e.currentTarget.value;
						// Store language preference
						const isUkrainian = newPath.startsWith('/uk/');
						localStorage.setItem('docs-preferred-lang', isUkrainian ? 'uk' : 'en');
						window.location.pathname = newPath;
					}
				});
			}
		}
	}
	customElements.define('language-select', LanguageSelect);
</script>

<style lang="scss">
	language-select {
		display: block;
		width: 100%;
	}

	label {
		--sl-label-icon-size: 0.875rem;
		--sl-caret-size: 1.25rem;
		position: relative;
		display: flex;
		align-items: center;
		width: 100%;
		color: var(--sl-color-gray-1);
		cursor: pointer;
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 0.5rem;
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
	}

	label:hover {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-6);
	}

	:global([data-theme='dark']) label {
		background-color: var(--sl-color-black);

		&:hover {
			background-color: var(--sl-color-gray-6);
		}
	}

	.icon {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		pointer-events: none;
	}

	.label-icon {
		font-size: var(--sl-label-icon-size);
		inset-inline-start: 0.75rem;
	}

	.caret {
		font-size: var(--sl-caret-size);
		inset-inline-end: 0.5rem;
	}

	select {
		border: 0;
		width: 100%;
		padding: 0.625rem 2.25rem 0.625rem 2.25rem;
		background-color: transparent;
		text-overflow: ellipsis;
		color: inherit;
		cursor: pointer;
		appearance: none;
		font-weight: 600;
		font-size: var(--sl-text-sm);
		line-height: var(--sl-line-height-headings);
	}

	option {
		background-color: var(--sl-color-bg-nav);
		color: var(--sl-color-gray-1);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
</style>
