---
// InstallationCardGrid.astro
// Responsive 3-column grid of installation cards.
// Each card is a link with a centered SVG icon and an h4 title below it.
//
// Usage:
//   <InstallationCardGrid items={[
//     { href: '/docs/installation/ubuntu/', title: 'Ubuntu', icon: '/src/assets/images/install/ubuntu.svg' },
//   ]} />

import { Badge } from '@astrojs/starlight/components';
import { Products, productDocsPrefix } from '~/models/site.models';

export interface CardItem {
	path?: string; // relative path, absolute URL, or omit for "Coming soon"
	title: string;
	icon: string; // SVG path inside /src/assets/
	accent?: string; // e.g. '#e63946' — sets --landing-card-accent on the card
	target?: string; // e.g. '_blank'
	badge?: string;  // Badge label, e.g. 'NEW'
	badgeVariant?: 'default' | 'note' | 'tip' | 'caution' | 'danger' | 'success';
	hero?: boolean; // Full-width card with horizontal layout and description
	description?: string; // Subtitle text shown below the title (hero cards only)
}

interface Props {
	items: CardItem[];
	product: Products;
}

const { items, product } = Astro.props;
const prefix = productDocsPrefix[product];

const svgModules = import.meta.glob<string>('/src/assets/**/*.svg', {
	eager: true,
	query: '?raw',
	import: 'default',
});

const processedItems = items.map((item) => {
	let href: string | null = null;
	if (item.path) {
		if (item.path.startsWith('http://') || item.path.startsWith('https://')) {
			href = item.path;
		} else {
			const [basePath, hash] = item.path.split('#');
			const normalizedPath = basePath.endsWith('/') ? basePath : basePath + '/';
			href = `/docs/${prefix}${normalizedPath}${hash ? '#' + hash : ''}`;
		}
	}
	return {
		...item,
		href,
		iconRaw: svgModules[item.icon] ?? null,
	};
});
---

<ul class:list={['ic-grid', { 'ic-grid--two': processedItems.length === 2 }]}>
	{
		processedItems.map((item) => (
			<li
				class:list={['ic-card', { 'ic-card--soon': !item.href, 'ic-card--hero': item.hero }]}
				style={item.accent ? `--landing-card-accent: ${item.accent}` : undefined}
			>
				{item.href ? (
					<a
						href={item.href}
						class="ic-card__link"
						target={item.target}
						rel={item.target === '_blank' ? 'noopener noreferrer' : undefined}
					>
						{(item.badge || !item.href) && (
							<div class="ic-card__badge">
								<Badge
									text={item.badge ?? 'Coming soon'}
									variant={item.badgeVariant ?? (item.badge ? 'default' : 'note')}
									size="small"
								/>
							</div>
						)}
						<div class="ic-card__icon" aria-hidden="true">
							{item.iconRaw && <Fragment set:html={item.iconRaw} />}
						</div>
						<div class="ic-card__text">
							<h4 class="ic-card__title">{item.title}</h4>
							{item.description && <p class="ic-card__desc">{item.description}</p>}
						</div>
					</a>
				) : (
					<div class="ic-card__link">
						<div class="ic-card__badge">
							<Badge
								text={item.badge ?? 'Coming soon'}
								variant={item.badgeVariant ?? (item.badge ? 'default' : 'note')}
								size="small"
							/>
						</div>
						<div class="ic-card__icon" aria-hidden="true">
							{item.iconRaw && <Fragment set:html={item.iconRaw} />}
						</div>
						<div class="ic-card__text">
							<h4 class="ic-card__title">{item.title}</h4>
							{item.description && <p class="ic-card__desc">{item.description}</p>}
						</div>
					</div>
				)}
			</li>
		))
	}
</ul>

<style>
	/* Grid — 3 columns desktop, 2 tablet, 1 mobile */
	.ic-grid {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.ic-grid--two {
		grid-template-columns: repeat(2, 1fr);
	}

@media (max-width: 900px) {
		.ic-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.ic-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Badge */
	.ic-card__badge {
		position: absolute;
		top: 1.5rem;
		inset-inline-end: 1.5rem;
		z-index: 1;
	}

	/* Card */
	.ic-card {
		position: relative;
		overflow: hidden;
		background: var(--card-bg);
		margin-top: 0;
		border: 1px solid var(--sl-color-gray-5);
		transition: border-color 0.15s;
	}
	
	.ic-card::before {
		content: "";
		position: absolute;
		top: 0;
		inset-inline-end: 0;
		width: 6.25rem;
		height: 6.25rem;
		background: var(--landing-card-accent, var(--sl-color-accent));
		border-radius: 100%;
		filter: blur(3.25rem);
		opacity: 0.33;
	}

	.ic-card:not(.ic-card--soon):hover {
		border-color: var(--sl-color-text-accent);
	}

	.ic-card--soon {
		opacity: 0.5;
		cursor: default;
	}

	.ic-card__link {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: start;
		gap: 1rem;
		margin-bottom: 0;
		padding: 2.5rem;
		text-decoration: none;
		color: inherit;
	}

	/* Icon area */
	.ic-card__icon {
		width: auto;
		height: 2.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.ic-card__icon svg {
		width: auto;
		height: 100%;
	}

	/* Text wrapper */
	.ic-card__text {
		display: contents;
	}

	/* Title */
	.ic-card__title {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 600;
		text-align: start;
		color: var(--sl-color-white);
		line-height: 1.4;
	}

	/* Description */
	.ic-card__desc {
		margin: 0;
		font-size: 0.9rem;
		color: var(--sl-color-gray-2);
		line-height: 1.5;
	}

	/* Hero card — full width, horizontal layout */
	.ic-card--hero {
		grid-column: 1 / -1;
	}

	.ic-card--hero .ic-card__link {
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
	}

	.ic-card--hero .ic-card__icon {
		height: 3rem;
	}

	.ic-card--hero .ic-card__text {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.ic-card--hero .ic-card__title {
		text-align: start;
	}

	@media (max-width: 480px) {
		.ic-card--hero .ic-card__link {
			flex-direction: column;
			align-items: start;
		}
	}
</style>
